---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import LiquidGlassCard from '../components/LiquidGlassCard.astro';
import ContactButton from '../components/ContactButton.astro';
import QRCodeButton from '../components/QRCodeButton.astro';
import ProfilePhotoModal from '../components/ProfilePhotoModal.astro';
import ChatHero from '../components/ChatHero.astro';
import LiquidGlassIcon from '../components/LiquidGlassIcon.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import resumeData from '../data/resume.json';
import { getVersionFooterData } from '../utils/version-footer';

const { basics, work, skills, education, projects, training } = resumeData;
const versionFooter = getVersionFooterData();

// Human-readable dates: "2025-11" -> "Nov 2025", "2023-08-01" -> "Aug 2023".
// Resumes should never show raw ISO date strings.
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmtDate = (iso) => {
  if (!iso) return '';
  const [y, m] = String(iso).split('-');
  const mi = parseInt(m, 10);
  return mi >= 1 && mi <= 12 ? `${MONTHS[mi - 1]} ${y}` : String(y);
};
// "Nov 2025 – Present" / "Aug 2023 – Aug 2024" (en dash, human months)
const fmtRange = (start, end) => `${fmtDate(start)} – ${end ? fmtDate(end) : 'Present'}`;

// Strip [TODO ...] placeholders so draft entries never render them on the live
// resume (same guard the chatbot applies). Text that is only a placeholder
// collapses to empty and is dropped from lists.
const stripTodo = (s) =>
  typeof s === 'string' ? s.replace(/\[TODO[^\]]*\]/g, '').replace(/\s{2,}/g, ' ').trim() : s;
const cleanList = (arr) => (arr || []).map(stripTodo).filter((x) => x && x.length > 0);

// Use build-time site URL from Astro config for consistent deployment URLs
// This leverages the same environment detection used in PDF API routes
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'http://localhost:4321';
---

<Layout title={`${basics.name} - ${basics.label}`} description={basics.summary}>
  <!-- AI-first: the chat hero IS the first viewport; classic resume below -->
  <ChatHero />

  <main id="resume-content" class="min-h-screen py-8 px-4">
    <div class="resume-shell mx-auto space-y-8 apple-motion-container">
      
      <!-- Hero Section with Advanced Liquid Glass -->
      <LiquidGlassCard variant="intense" class="text-center p-8 md:p-12 apple-section-animate">
        <div class="mb-6">
          <button 
            onclick={`showProfileModal('${basics.image}', '${basics.name}', '${basics.label}')`}
            class="profile-photo-button cursor-pointer transform transition-all duration-300 hover:scale-105 hover:shadow-2xl"
            aria-label={`View ${basics.name}'s profile photo in larger size`}
            type="button"
          >
            <ResponsiveImage 
              src={basics.image} 
              alt={basics.name}
              class="w-32 h-32 mx-auto rounded-full border-4 border-white/20 shadow-2xl"
              loading="eager"
              fetchpriority="high"
              width={128}
              height={128}
            />
          </button>
        </div>
        
        <!-- Apple-Style Name and Title Section -->
        <div class="text-center mb-8">
          <h1 class="apple-display-large mb-3">
            {basics.name}
          </h1>

          <h2 class="apple-subtitle mb-4">
            {basics.label}
          </h2>

          <!-- Location Badge -->
          <div class="location-badge">
            <a
              href="https://maps.google.com/?q=Christ+the+Redeemer,+Rio+de+Janeiro,+Brazil"
              target="_blank"
              rel="noopener noreferrer"
              class="location-link"
              aria-label="View location on Google Maps"
              title={`${basics.location.city}, ${basics.location.region}`}
            >
              <Icon name="heroicons:map-pin" class="location-pin" />
              <span class="location-text">{basics.location.city}, {basics.location.region}</span>
            </a>
          </div>
        </div>

        <!-- Professional Summary with Apple Typography -->
        <div class="apple-summary-block">
          <p class="apple-body leading-relaxed apple-smart-break">
            {basics.summary}
          </p>
        </div>
      </LiquidGlassCard>

      <!-- Apple HIG Subtle Separator -->
      <div class="apple-separator" aria-hidden="true"></div>
      
      <!-- Connect & Download Section -->
      <LiquidGlassCard class="p-8 apple-section-animate" data-apple-delay="1">
        <h2 class="apple-section-title">Let's Connect</h2>

        <!-- Contact Methods -->
        <div class="mb-8">
          <h3 class="apple-overline mb-4">Get In Touch</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            <!-- Email -->
            <ContactButton
              icon="heroicons:envelope"
              label="Email"
              value={basics.email}
              href={`mailto:${basics.email}`}
              network="Email"
            />

            <!-- Phone -->
            <ContactButton
              icon="heroicons:phone"
              label="Phone"
              value={basics.phone}
              href={`tel:${basics.phone}`}
              network="Phone"
            />

            <!-- LinkedIn -->
            <ContactButton
              icon="simple-icons:linkedin"
              label="LinkedIn"
              value="Professional profile"
              href="https://www.linkedin.com/in/rafaelbsathler/"
              network="LinkedIn"
            />

            <!-- GitHub -->
            <ContactButton
              icon="simple-icons:github"
              label="GitHub"
              value="Code & projects"
              href="https://github.com/rafilkmp3"
              network="GitHub"
            />

            <!-- Cal.com -->
            <ContactButton
              icon="heroicons:calendar"
              label="Check Availability"
              value="Book a meeting"
              href="https://cal.com/rafaelbsathler"
              network="cal.com"
            />

            <!-- WhatsApp -->
            <ContactButton
              icon="simple-icons:whatsapp"
              label="WhatsApp"
              value="Chat with me"
              href="https://wa.me/5521997988682"
              network="WhatsApp"
            />

            <!-- Repository Link -->
            <ContactButton
              icon="heroicons:code-bracket-square"
              label="Repository"
              value="See this resume source code"
              href="https://github.com/rafilkmp3/resume-as-code"
              network="Repository"
            />

            <!-- QR Code Button - Available on all devices -->
            <QRCodeButton url={siteUrl} />
          </div>
        </div>

        <!-- PDF Downloads -->
        <div>
          <h3 class="apple-overline mb-4">Download Resume</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a 
              href={`${siteUrl}/pdf-screen`}
              class="glass-button-modern flex items-center px-6 py-4 font-medium transition-all group"
              target="_blank"
              rel="noopener noreferrer"
              data-pdf-type="screen"
            >
              <div class="mr-3">
                <LiquidGlassIcon name="heroicons:computer-desktop" size={20} variant="subtle" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold">View Online</div>
                <div class="text-xs opacity-80">Interactive version</div>
              </div>
            </a>
            <a 
              href={`${siteUrl}/pdf-print`}
              class="glass-button-modern flex items-center px-6 py-4 font-medium transition-all group"
              target="_blank"
              rel="noopener noreferrer"
              data-pdf-type="print"
            >
              <div class="mr-3">
                <LiquidGlassIcon name="heroicons:printer" size={20} variant="subtle" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold">Print PDF</div>
                <div class="text-xs opacity-80">Printer-friendly</div>
              </div>
            </a>
            <a 
              href={`${siteUrl}/pdf-ats`}
              class="glass-button-modern flex items-center px-6 py-4 font-medium transition-all group"
              target="_blank"
              rel="noopener noreferrer"
              data-pdf-type="ats"
            >
              <div class="mr-3">
                <LiquidGlassIcon name="heroicons:cpu-chip" size={20} variant="subtle" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold">ATS PDF</div>
                <div class="text-xs opacity-80">Machine-readable</div>
              </div>
            </a>
          </div>
        </div>
      </LiquidGlassCard>

      <!-- Apple HIG Subtle Separator -->
      <div class="apple-separator" aria-hidden="true"></div>
      
      <!-- Experience Section -->
      <LiquidGlassCard class="p-8 apple-section-animate" data-apple-delay="2">
        <h2 class="apple-section-title">Professional Experience</h2>
        <div class="space-y-8" id="experience-container">
          {work.map((job, index) => (
            <div class={`experience-item ${index >= 3 ? 'hidden' : ''}`}>
              {/* Apple HIG Job Separator */}
              {index > 0 && <div class="apple-job-separator" aria-hidden="true"></div>}
              <div class="apple-experience-container">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
                <div>
                  <h3 class="apple-title-2">{job.position}</h3>
                  {job.url ? (
                    <a 
                      href={job.url} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="apple-title-3 hover:underline transition-all duration-200"
                      style="color: var(--link-color);"
                    >
                      {job.name}
                    </a>
                  ) : (
                    <p class="apple-title-3">{job.name}</p>
                  )}
                </div>
                <h5 class="apple-date-badge">
                  {fmtRange(job.startDate, job.endDate)}
                </h5>
              </div>
              
                {stripTodo(job.summary) && <p class="apple-experience-summary">{stripTodo(job.summary)}</p>}

                {cleanList(job.highlights).length > 0 && (
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4">
                    {cleanList(job.highlights).map((highlight) => (
                      <div class="apple-highlight-card">
                        <p class="apple-highlight-text">{highlight}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
        
        <!-- Load More Button for Experience -->
        {work.length > 3 && (
          <div class="text-center mt-8">
            <button 
              id="load-more-experience"
              class="glass-button-modern inline-flex items-center justify-center gap-2 px-8 py-3 rounded-lg font-medium transition-all group"
              onclick="toggleExperienceItems()"
            >
              <LiquidGlassIcon name="heroicons:chevron-down" size={20} variant="subtle" />
              <span id="experience-button-text">Show More Experience</span>
            </button>
          </div>
        )}
      </LiquidGlassCard>

      <!-- Apple HIG Subtle Separator -->
      <div class="apple-separator" aria-hidden="true"></div>
      
      <!-- Key Projects Section -->
      <LiquidGlassCard class="p-8 apple-section-animate" data-apple-delay="3">
        <h2 class="apple-section-title">Key Projects</h2>
        <div class="space-y-8 2xl:columns-2 2xl:gap-8 2xl:space-y-0" id="projects-container">
          {projects.map((project, index) => (
            <div class={`project-item ${index >= 3 ? 'hidden' : ''}`}>
              {/* Apple HIG Project Separator */}
              {index > 0 && <div class="apple-job-separator" aria-hidden="true"></div>}
              <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
                <div class="flex-1">
                  <h3 class="apple-title-2 mb-2">
                    {project.url ? (
                      <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: var(--link-color);">
                        {project.name}
                      </a>
                    ) : project.name}
                  </h3>
                  {stripTodo(project.description) && <p class="apple-experience-summary">{stripTodo(project.description)}</p>}
                </div>
              </div>

              {cleanList(project.highlights).length > 0 && (
                <div class="grid grid-cols-1 gap-3 mb-4">
                  {cleanList(project.highlights).map((highlight) => (
                    <div class="apple-highlight-card">
                      <p class="apple-highlight-text">{highlight}</p>
                    </div>
                  ))}
                </div>
              )}

              {project.keywords && (
                <div class="flex flex-wrap gap-2">
                  {project.keywords.map((keyword) => (
                    <span class="glass-token apple-subheadline transition-all duration-200">
                      {keyword}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
        
        <!-- Load More Button for Projects -->
        {projects.length > 3 && (
          <div class="text-center mt-8">
            <button 
              id="load-more-projects"
              class="glass-button-modern inline-flex items-center justify-center gap-2 px-8 py-3 rounded-lg font-medium transition-all group"
              onclick="toggleProjectItems()"
            >
              <LiquidGlassIcon name="heroicons:chevron-down" size={20} variant="subtle" />
              <span id="projects-button-text">Show More Projects</span>
            </button>
          </div>
        )}
      </LiquidGlassCard>

      <!-- Apple HIG Subtle Separator -->
      <div class="apple-separator" aria-hidden="true"></div>
      
      <!-- Training Section -->
      {training && training.length > 0 && (
        <>
          <LiquidGlassCard class="p-8 apple-section-animate" data-apple-delay="4">
            <h2 class="apple-section-title">Training</h2>
            <div class="space-y-6">
              {training.map((cert, index) => (
                <div class="certification-item">
                  {index > 0 && <div class="apple-job-separator" aria-hidden="true"></div>}
                  
                  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-3">
                    <div class="flex-1">
                      <h3 class="apple-title-2">
                        {cert.courseUrl ? (
                          <a 
                            href={cert.courseUrl} 
                            target="_blank" 
                            rel="noopener noreferrer"
                            class="hover:underline transition-all duration-200"
                            style="color: var(--link-color);"
                          >
                            {cert.name}
                          </a>
                        ) : (
                          cert.name
                        )}
                      </h3>
                      <div class="apple-title-3">
                        {cert.issuerUrl ? (
                          <a 
                            href={cert.issuerUrl} 
                            target="_blank" 
                            rel="noopener noreferrer"
                            class="hover:underline transition-all duration-200"
                            style="color: var(--link-color);"
                          >
                            {cert.issuer}
                          </a>
                        ) : (
                          cert.issuer
                        )}
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="apple-footnote">{fmtDate(cert.date)}</span>
                      <div class="flex gap-2">
                        {cert.url && (
                          <a 
                            href={cert.url} 
                            target="_blank" 
                            rel="noopener noreferrer"
                            class="glass-button-modern inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium transition-all hover:scale-105"
                            aria-label={`View ${cert.name} certificate PDF`}
                          >
                            <LiquidGlassIcon name="heroicons:academic-cap" size={16} variant="subtle" class="mr-2" />
                            View Certificate
                          </a>
                        )}
                        {cert.digitalBadge && cert.digitalBadge.url && (
                          <a 
                            href={cert.digitalBadge.url} 
                            target="_blank" 
                            rel="noopener noreferrer"
                            class="glass-button-modern inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium transition-all hover:scale-105"
                            aria-label={`View ${cert.name} digital badge on Credly`}
                          >
                            <LiquidGlassIcon name="heroicons:shield-check" size={16} variant="subtle" class="mr-2" />
                            Digital Badge
                          </a>
                        )}
                      </div>
                    </div>
                  </div>

                  {cert.highlights && cert.highlights.length > 0 && (
                    <ul class="space-y-1 mb-4">
                      {cert.highlights.map((highlight) => (
                        <li class="apple-body leading-relaxed">
                          {highlight}
                        </li>
                      ))}
                    </ul>
                  )}

                  {cert.keywords && cert.keywords.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {cert.keywords.map((keyword) => (
                        <span class="glass-token apple-subheadline opacity-90">
                          {keyword}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </LiquidGlassCard>

          <!-- Apple HIG Subtle Separator -->
          <div class="apple-separator" aria-hidden="true"></div>
        </>
      )}
      
      <!-- Skills Section -->
      <LiquidGlassCard class="p-8 apple-section-animate" data-apple-delay="5">
        <h2 class="apple-section-title">Technical Skills</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-6">
          {skills.map((skillGroup, index) => {
            // Map skill groups to appropriate icons (removing emoji duplication)
            const skillIcons = [
              'heroicons:cloud',              // Cloud Platforms & IaC
              'simple-icons:kubernetes',      // Container Orchestration  
              'heroicons:arrow-path',         // CI/CD & DevOps
              'heroicons:chart-bar',          // Observability & Monitoring
              'heroicons:code-bracket',       // Programming & Scripting
              'heroicons:server',             // Big Data & Databases
              'heroicons:shield-check',       // Security & Compliance
              'heroicons:users'               // Soft Skills
            ];
            
            const iconName = skillIcons[index] || 'heroicons:wrench-screwdriver';
            
            return (
              <div class="glass-card p-6 space-y-4">
                <h3 class="apple-headline flex items-center">
                  <div class="mr-2">
                    <LiquidGlassIcon name={iconName} size={20} variant="default" />
                  </div>
                  {skillGroup.name}
                </h3>
                <div class="flex flex-wrap gap-2">
                  {skillGroup.keywords.map((skill) => {
                    const hasLink = skillGroup.links && skillGroup.links[skill];
                    const Component = hasLink ? 'a' : 'span';
                    const linkProps = hasLink ? {
                      href: skillGroup.links[skill],
                      target: '_blank',
                      rel: 'noopener noreferrer',
                      title: `Learn more about ${skill} - Educational resource`,
                      'data-contact-type': 'skill-education',
                      'data-contact-value': skill
                    } : {};
                    
                    return (
                      <Component
                        class={`glass-token apple-subheadline transition-all duration-200 ${hasLink ? 'hover:scale-105 hover:shadow-lg cursor-pointer' : 'opacity-90'}`}
                        style="color: var(--glass-text);"
                        {...linkProps}
                      >
                        {skill}
                      </Component>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>
      </LiquidGlassCard>


    </div>

    <!-- Footer with Version Link -->
    <footer class="text-center py-6 mt-8">
      <a
        href={versionFooter.href}
        target="_blank"
        rel="noopener noreferrer"
        class="version-link"
        aria-label={versionFooter.ariaLabel}
      >
        {versionFooter.text}
      </a>
    </footer>
  </main>
  
  <!-- Profile Photo Modal -->
  <ProfilePhotoModal 
    name={basics.name}
    imageSrc={basics.image}
    title={basics.label}
  />

</Layout>

<style>
  /* Glass button modern base styles now defined in Layout.astro */
  .glass-button-modern {
    border-radius: 16px;
    text-decoration: none;
    font-weight: 600;
  }

  .glass-button-modern:hover span {
    transform: scale(1.1);
  }

  .glass-icon-container-small {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .glass-button-modern:hover .glass-icon-container-small {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }

  /* Profile Photo Button Styling - Apple-style clickable profile photo */
  .profile-photo-button {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    display: inline-block;
    cursor: pointer;
    border-radius: 50%;
    position: relative;
    overflow: hidden;
  }

  .profile-photo-button::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .profile-photo-button:hover::after {
    opacity: 1;
  }

  .profile-photo-button:focus {
    outline: 3px solid rgba(37, 99, 235, 0.5);
    outline-offset: 4px;
  }

  /* Apple-style focus ring */
  .profile-photo-button:focus:not(:focus-visible) {
    outline: none;
  }
  
  .icon-svg-small {
    filter: invert(var(--icon-invert, 0.2));
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .glass-button-modern:hover .icon-svg-small {
    filter: invert(var(--icon-invert, 0.2)) sepia(1) saturate(2) hue-rotate(var(--icon-hue, 200deg));
  }

  /* Color + glass tokens now live in app/styles/global.css (single owner). */

  /* Shared page + text layout helpers */
  .resume-shell {
    max-width: var(--container-max);
  }

  .apple-summary-block {
    /* Hero bio: a short, deliberately-centered blurb under the centered name
       and title, so the whole hero card reads as one centered unit (no
       left-floating block). Narrower measure keeps centered lines balanced. */
    max-width: 54ch;
    margin: 0 auto;
    text-align: center;
    text-wrap: pretty;
  }

  /* Sub-group label (overline) — subordinate to section titles, distinct from
     job titles which share h3/.apple-title-2. */
  .apple-overline {
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--foreground-muted);
    margin-bottom: var(--space-4);
  }

  /* Wide Screen Layout Optimizations */
  @media (min-width: 1536px) {
    /* Projects can use columns since chronological order doesn't matter */
    .project-item {
      break-inside: avoid;
      page-break-inside: avoid;
      margin-bottom: 2rem;
      display: block;
    }
    
    /* Ensure proper spacing in column layout for projects */
    #projects-container .project-item:not(:last-child) {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 2rem;
    }
    
    /* Experience maintains single column for chronological timeline */
    .experience-item {
      margin-bottom: 2rem;
    }
  }

  /* Responsive readability optimization */
  @media (min-width: 1280px) and (max-width: 1535px) {
    /* xl screens: optimize spacing for better readability */
    .experience-item, .project-item {
      margin-bottom: 1.5rem;
    }
  }

  /* ===== APPLE HIG MOTION DESIGN & SUBTLE SEPARATORS ===== */
  
  /* Apple HIG Subtle Separators (Vibrancy Style) */
  .apple-separator {
    height: 1px;
    margin: 3rem auto;
    max-width: 600px;
    background: linear-gradient(
      90deg, 
      transparent 0%, 
      var(--separator-dark) 20%, 
      var(--separator-light) 50%, 
      var(--separator-dark) 80%, 
      transparent 100%
    );
    position: relative;
    overflow: hidden;
  }

  .apple-separator::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 100%
    );
    animation: apple-separator-shine 3s ease-in-out infinite;
  }

  :global(.dark) .apple-separator::before {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.2) 50%,
      transparent 100%
    );
  }

  @keyframes apple-separator-shine {
    0% { left: -100%; }
    50% { left: 100%; }
    100% { left: 100%; }
  }

  /* Apple HIG Job Separators (More Subtle for Content Items) */
  .apple-job-separator {
    height: 0.5px;
    margin: 2rem auto 2rem;
    max-width: 400px;
    background: linear-gradient(
      90deg, 
      transparent 0%, 
      var(--separator-dark) 30%, 
      var(--separator-light) 50%, 
      var(--separator-dark) 70%, 
      transparent 100%
    );
    position: relative;
    opacity: 0.8;
  }

  /* Dark Theme Adaptations for Contact Icons */
  :global(.dark) .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(0, 0, 0, 0.15) 0%,
      rgba(0, 0, 0, 0.08) 50%,
      rgba(0, 0, 0, 0.15) 100%
    );
    
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 1px 0 rgba(255, 255, 255, 0.03);
    
    border-color: rgba(255, 255, 255, 0.08);
  }
  
  :global(.dark) .apple-contact-badge:hover .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.12) 50%,
      rgba(0, 0, 0, 0.25) 100%
    );
    
    box-shadow: 
      0 12px 40px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 2px 0 rgba(255, 255, 255, 0.05);
    
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Apple HIG Motion Container */
  .apple-motion-container {
    /* Enable staggered animations */
    counter-reset: section-counter;
  }

  /* Apple HIG Section Animations (Beautiful & Fluid) */
  .apple-section-animate {
    opacity: 0;
    transform: translateY(40px);
    animation: apple-section-appear 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    counter-increment: section-counter;
  }

  .apple-section-animate[data-apple-delay="1"] {
    animation-delay: 0.2s;
  }

  .apple-section-animate[data-apple-delay="2"] {
    animation-delay: 0.4s;
  }

  .apple-section-animate[data-apple-delay="3"] {
    animation-delay: 0.6s;
  }

  .apple-section-animate[data-apple-delay="4"] {
    animation-delay: 0.8s;
  }

  @keyframes apple-section-appear {
    0% {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Apple HIG Breathing Animation for Accent Elements */
  .apple-breathe {
    animation: apple-breathe 4s ease-in-out infinite;
  }

  @keyframes apple-breathe {
    0%, 100% { 
      opacity: 1; 
      transform: scale(1); 
    }
    50% { 
      opacity: 0.7; 
      transform: scale(1.05); 
    }
  }

  /* Enhanced Apple HIG Button Animations - base surface from Layout.astro tokens */
  .glass-button-modern {
    /* Apple's preferred cubic-bezier for fluid motion */
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform-origin: center;
    border-radius: var(--radius-lg);
    min-height: var(--tap-min); /* HIG touch target */
  }

  .glass-button-modern:active {
    /* Apple HIG Quick feedback on tap */
    transform: translateY(-1px) scale(0.98);
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Apple HIG Token (capsule) — single canonical definition, accent-tinted
     glass from shared tokens. */
  .glass-token {
    background: var(--glass-accent-bg);
    backdrop-filter: var(--glass-filter-sm);
    -webkit-backdrop-filter: var(--glass-filter-sm);
    border: 1px solid var(--glass-accent-border);
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-4);
    color: var(--glass-text);
    text-decoration: none;
    font-weight: var(--fw-medium);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
    /* Apple's spring-like easing for tokens */
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transform-origin: center;
  }

  /* Interactive tokens are real tap targets — meet the 44px HIG minimum. */
  a.glass-token,
  button.glass-token {
    min-height: var(--tap-min);
  }

  .glass-token:hover {
    background: var(--glass-accent-hover-bg);
    border-color: var(--glass-accent-hover-border);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.25);
    /* Apple HIG Gentle lift with slight scale */
    transform: translateY(-2px) scale(1.03);
  }

  .glass-token:active {
    transform: translateY(0px) scale(0.97);
    transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Apple HIG Reduced Motion Support */
  @media (prefers-reduced-motion: reduce) {
    .apple-section-animate,
    .apple-separator::before,
    .apple-job-separator::before {
      animation: none;
    }
    
    .apple-section-animate {
      opacity: 1;
      transform: none;
    }
    
    .glass-button-modern:hover,
    .glass-token:hover {
      transform: none;
    }
  }

  /* ===== MOBILE VIEWPORT OPTIMIZATIONS (IPHONE 15 PRO MAX & SIMILAR) ===== */
  
  @media (max-width: 430px) {
    /* Apple HIG: Optimize spacing for iPhone 15 Pro Max (430px) */
    .apple-motion-container {
      space-y: 6rem; /* Increased spacing between sections */
    }

    /* Contact buttons: Better mobile grid layout */
    .grid.grid-cols-1.sm\\:grid-cols-2.lg\\:grid-cols-3.xl\\:grid-cols-4 {
      grid-template-columns: 1fr 1fr; /* 2 columns on mobile for better space usage */
      gap: 0.75rem; /* Tighter gaps for mobile */
    }
    
    /* Skills grid: Optimize for mobile readability */
    .grid.grid-cols-1.md\\:grid-cols-2.lg\\:grid-cols-3.xl\\:grid-cols-4 {
      grid-template-columns: 1fr; /* Single column on mobile for readability */
      gap: 1rem;
    }
    
    /* PDF download buttons: Stack vertically on mobile */
    .grid.grid-cols-1.sm\\:grid-cols-3 {
      grid-template-columns: 1fr; /* Single column for mobile */
      gap: 0.75rem;
    }
    
    /* Apple HIG: Larger touch targets for mobile */
    .glass-button-modern {
      min-height: 48px; /* Apple HIG minimum touch target */
      padding: 1rem 1.5rem;
    }
    
    .glass-token {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-footnote); /* readable label size on mobile */
    }
    
    /* Apple HIG: Reduce animation intensity on mobile for comfort */
    .apple-section-animate {
      animation-duration: 0.6s; /* Faster animations on mobile */
    }
    
    .glass-button-modern:hover {
      transform: translateY(-1px) scale(1.01); /* Reduced motion on mobile */
    }
    
    .glass-token:hover {
      transform: translateY(-1px) scale(1.02); /* Gentler mobile interactions */
    }
  }

  /* ===== MACBOOK RETINA OPTIMIZATIONS (2560PX & SIMILAR) ===== */
  
  @media (min-width: 2560px) {
    /* Wide screen container optimization */
    .resume-shell {
      max-width: 96rem; /* 1536px - even wider on large displays */
    }
    
    /* Skills: Use more columns on very wide screens */
    .grid.grid-cols-1.md\\:grid-cols-2.lg\\:grid-cols-3.xl\\:grid-cols-4.\\32xl\\:grid-cols-5 {
      grid-template-columns: repeat(6, 1fr); /* 6 columns on ultra-wide */
    }
    
    /* Contact buttons: Better distribution on wide screens */
    .grid.grid-cols-1.sm\\:grid-cols-2.lg\\:grid-cols-3.xl\\:grid-cols-4 {
      grid-template-columns: repeat(4, 1fr); /* 4 columns for contact buttons on ultra-wide */
    }
    
    /* Apple HIG: Optimize sections for wide screen viewing */
    .apple-motion-container {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  /* ===== APPLE HIG COMPREHENSIVE TYPOGRAPHY SYSTEM ===== */
  /* Fluid typography that prevents text from being too big or too small */
  
  /* All sizes/weights/line-heights/tracking draw from the shared tokens in
     app/styles/global.css. One rule per level; levels are unambiguously
     ranked (caption 13 < footnote 14 < body 16 < callout 17 < headline 18+). */

  /* Display Large — Hero name only (h1). Bold (not 800): size + tight
     tracking already carry the display hierarchy. */
  .apple-display-large, h1 {
    font-size: var(--text-display);
    font-weight: var(--fw-bold);
    line-height: var(--lh-display);
    letter-spacing: var(--tracking-display);
    color: var(--foreground);
    font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
    font-optical-sizing: auto;
    margin-bottom: clamp(1rem, 2.5vw, 2rem);
  }

  /* Large Title — Major section headers (h2) */
  .apple-section-title, h2 {
    font-size: var(--text-title-1);
    font-weight: var(--fw-bold);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-title);
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
    color: var(--foreground);
    font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
  }

  /* Title 1 — distinct larger subsection tier (kept separate from Title 2) */
  .apple-title-1 {
    font-size: var(--text-title-1);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-title);
    color: var(--foreground);
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  /* Title 2 — Job / project titles (h3) */
  .apple-title-2, h3 {
    font-size: var(--text-title-2);
    font-weight: var(--fw-semibold);
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
    color: var(--foreground);
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  /* Title 3 — Company / issuer names (h4) */
  .apple-title-3, h4 {
    font-size: var(--text-title-3);
    font-weight: var(--fw-medium);
    line-height: 1.35;
    letter-spacing: var(--tracking-tight);
    color: var(--foreground);
    margin-bottom: clamp(0.5rem, 1vw, 1rem);
  }

  /* Headline — Skill category headers */
  .apple-headline {
    font-size: var(--text-headline);
    font-weight: var(--fw-semibold);
    line-height: 1.4;
    letter-spacing: var(--tracking-tight);
    color: var(--link-color);
    margin-bottom: clamp(0.75rem, 1.25vw, 1rem);
  }

  /* h5 — Metadata like job dates. Separated from body by muted color, not
     just a fractional size step. */
  h5 {
    font-size: var(--text-footnote);
    font-weight: var(--fw-medium);
    line-height: 1.45;
    letter-spacing: var(--tracking-label);
    color: var(--foreground-muted);
    margin-bottom: clamp(0.25rem, 0.5vw, 0.5rem);
  }

  /* Job / project date range — right-anchored, tabular digits so ranges line
     up column-to-column, never wraps mid-range. */
  .apple-date-badge {
    flex-shrink: 0;
    align-self: flex-start;
    font-size: var(--text-footnote);
    font-weight: var(--fw-medium);
    line-height: 1.45;
    letter-spacing: var(--tracking-label);
    color: var(--foreground-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    margin-top: var(--space-1);
  }
  @media (min-width: 768px) {
    .apple-date-badge { margin-top: 0; }
  }

  /* Subtitle — Job title under hero name */
  .apple-subtitle {
    font-size: var(--text-subtitle);
    font-weight: var(--fw-medium);
    line-height: 1.35;
    letter-spacing: var(--tracking-tight);
    color: var(--foreground-muted);
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    text-align: center;
  }

  /* Subheadline — Small labels / capsule tokens (h6). One definition only. */
  .apple-subheadline, h6 {
    font-size: var(--text-footnote);
    font-weight: var(--fw-medium);
    line-height: 1.45;
    letter-spacing: var(--tracking-label);
    color: var(--foreground);
    margin-bottom: clamp(0.25rem, 0.5vw, 0.5rem);
  }

  /* Body — Main content. Floor is 16px (never smaller); capped to a reading
     measure on block-level text. Label classes opt out so they stay their
     ranked size. */
  .apple-body,
  p,
  li,
  span:not(.apple-contact-label):not(.apple-contact-value):not(.apple-subheadline):not(.apple-footnote):not(.location-text) {
    font-size: var(--text-body);
    font-weight: var(--fw-regular);
    line-height: var(--lh-body);
    letter-spacing: 0;
    color: var(--foreground);
    text-wrap: balance;
    margin-bottom: clamp(0.75rem, 1.25vw, 1rem);
  }

  p, li {
    max-width: var(--measure);
  }

  /* Apple-Style Text Flow Enhancement */
  .apple-text-flow {
    text-align: left;
    overflow-wrap: break-word;
    line-height: 1.6;
    max-width: var(--measure);
  }

  /* Smart line breaking for responsive text */
  .apple-smart-break {
    text-wrap: balance;
    word-spacing: normal;
    hanging-punctuation: first last;
  }

  /* Enhanced paragraph spacing */
  .apple-paragraph-spacing > * + * {
    margin-top: 1.5em;
  }

  /* Callout — Secondary info; ranked just above body via size + muted color */
  .apple-callout {
    font-size: var(--text-callout);
    font-weight: var(--fw-regular);
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--foreground-muted);
  }

  /* Footnote — Small captions (dates, meta). 14px, ranked above caption. */
  .apple-footnote {
    font-size: var(--text-footnote);
    font-weight: var(--fw-regular);
    line-height: 1.4;
    letter-spacing: var(--tracking-label);
    color: var(--foreground-muted);
  }

  /* Old .apple-display-large removed - now using fluid h1 system */

  /* Apple-Style Contact Badge Components with Smart Text Handling */
  .apple-contact-badge {
    display: flex;
    align-items: center;
    padding: clamp(0.75rem, 1.5vw, 1rem) clamp(0.875rem, 2vw, 1.25rem);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(15px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px; /* Apple HIG rounded corners */
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    min-width: 0; /* Allow flex shrinkage */
    width: 100%; /* Full width for better text space */
    box-sizing: border-box;
    /* Smart text handling - prevents awkward line breaks */
    container-type: inline-size; /* Enable container queries */
  }

  .apple-contact-badge:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.25);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .apple-contact-icon {
    width: 44px;
    height: 44px;
    /* Liquid Glass Background - Matching LiquidGlassIcon component */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0.1) 100%
    );
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    /* Enhanced shadows for depth */
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .apple-contact-badge:hover .apple-contact-icon {
    transform: translateY(-2px) scale(1.05);
    /* Enhanced lighting on hover */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(255, 255, 255, 0.15) 100%
    );
    /* Intensified shadows and highlights */
    box-shadow: 
      0 12px 40px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 2px 0 rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .apple-contact-info {
    flex: 1;
    min-width: 0; /* Allows text truncation */
    overflow: hidden; /* Prevent content overflow */
  }

  .apple-contact-label {
    font-size: clamp(0.75rem, 1vw, 0.8125rem); /* Fluid: 12pt - 13pt */
    font-weight: 500;
    line-height: 1.2;
    color: var(--foreground);
    opacity: 0.7;
    margin-bottom: 2px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    white-space: nowrap; /* Prevent label wrapping */
  }

  .apple-contact-value {
    font-size: clamp(0.875rem, 1.25vw, 0.9375rem); /* Fluid: 14pt - 15pt */
    font-weight: 600;
    line-height: 1.3;
    color: var(--foreground);
    /* Apple HIG Smart Text Handling - Responsive Approach */
    overflow-wrap: break-word;
    word-break: normal; /* Changed from break-word to prevent awkward breaks */
    hyphens: auto;
    /* Default: Single line with ellipsis */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Container queries for responsive text handling */
  @container (min-width: 200px) {
    .apple-contact-value {
      white-space: normal; /* Allow wrapping on wider containers */
      overflow: visible;
      text-overflow: unset;
      word-spacing: -0.02em; /* Tighter word spacing for better fit */
    }
  }
  
  /* Enhanced responsive breakpoints for contact badges */
  @media (max-width: 640px) {
    .apple-contact-badge {
      padding: 0.75rem 0.875rem; /* Tighter on mobile */
      min-height: 60px; /* Ensure touch target */
    }
    
    .apple-contact-value {
      font-size: 0.875rem; /* 14pt on mobile */
      line-height: 1.25;
      /* Mobile: Allow controlled wrapping */
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
      hyphens: auto;
      word-break: break-word;
      /* Limit to 2 lines maximum on mobile */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  /* Remove old mobile/desktop scaling - now using fluid typography */

  /* Apple-Style Highlight Cards - Clean text-only styling */
  .apple-highlight-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px) saturate(110%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    transition: all 0.2s ease-out;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
    position: relative;
  }

  .apple-highlight-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, 
      rgba(var(--link-color-rgb, 30, 64, 175), 0.3) 0%, 
      rgba(var(--link-color-rgb, 30, 64, 175), 0.1) 50%,
      transparent 100%
    );
    opacity: 0.6;
  }

  .apple-highlight-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }


  .apple-highlight-text {
    font-size: var(--text-body); /* body floor — bullets are reading content */
    line-height: var(--lh-body);
    color: var(--foreground);
    margin: 0;
    font-weight: var(--fw-regular); /* Normal weight for better readability */
    overflow-wrap: break-word;
    hyphens: auto;
  }

  /* Dark theme adaptations for highlight cards */
  :global(.dark) .apple-highlight-card {
    background: rgba(0, 0, 0, 0.08);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
  }

  :global(.dark) .apple-highlight-card:hover {
    background: rgba(0, 0, 0, 0.12);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }


  /* CSS custom properties for color calculations */
  :root {
    --link-color-rgb: 30, 64, 175;
  }

  :global(.dark) {
    --link-color-rgb: 96, 165, 250;
  }

  /* Responsive adjustments for highlight cards */
  @media (max-width: 768px) {
    .apple-highlight-card {
      padding: var(--space-3);
      gap: 0.625rem;
    }
    
    .apple-highlight-icon {
      width: 20px;
      height: 20px;
      border-radius: 6px;
    }
    
    .apple-highlight-text {
      font-size: var(--text-body); /* keep at body floor on mobile too */
      line-height: 1.45;
    }
  }

  /* Apple Experience Container - Clean liquid glass hover boundaries */
  .apple-experience-container {
    border-radius: var(--radius-lg);
    /* Negative margin equals the padding so the hover surface insets
       symmetrically to a predictable, on-grid offset. */
    padding: var(--space-4);
    margin: calc(-1 * var(--space-4));
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .apple-experience-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px) saturate(120%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .apple-experience-container:hover::before {
    opacity: 1;
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .apple-experience-container:hover {
    transform: translateY(-1px);
  }

  /* Dark theme for experience container */
  :global(.dark) .apple-experience-container::before {
    background: rgba(0, 0, 0, 0.15);
    border-color: rgba(255, 255, 255, 0.04);
  }

  :global(.dark) .apple-experience-container:hover::before {
    background: rgba(0, 0, 0, 0.25);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  /* Enhanced Experience Summary Typography */
  .apple-experience-summary {
    font-size: clamp(1rem, 1.5vw, 1.125rem); /* 16pt - 18pt fluid */
    font-weight: var(--fw-regular); /* Apple standard body weight - lighter and more readable */
    line-height: 1.55; /* was a no-op clamp(); single real value */
    letter-spacing: -0.002em; /* More subtle negative tracking */
    color: var(--foreground);
    margin-bottom: var(--space-5);
    text-wrap: balance;
    max-width: var(--measure); /* single shared reading measure */
    font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
    font-optical-sizing: auto;
    /* Apple HIG text rendering optimization */
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Mobile adjustments for experience summary */
  @media (max-width: 640px) {
    .apple-experience-container {
      padding: var(--space-4);
      margin: calc(-1 * var(--space-4));
    }
    
    .apple-experience-summary {
      font-size: 1rem; /* 16pt on mobile */
      line-height: 1.5;
      margin-bottom: 1rem;
    }
  }

  /* Version Link Styling - Subtle footer link */
  .version-link {
    font-size: 0.75rem; /* 12pt - small text */
    font-weight: 500;
    color: var(--foreground);
    opacity: 0.5;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    display: inline-block;
  }

  .version-link:hover {
    opacity: 0.8;
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  :global(.dark) .version-link:hover {
    background: rgba(0, 0, 0, 0.1);
  }

  /* Location Badge Styling - Hero section location */
  .location-badge {
    display: flex;
    justify-content: center;
    margin: var(--space-2) 0;
  }

  /* Subtle pill: small pin + text, both centered vertically and the pill
     itself centered horizontally under the title. */
  .location-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: var(--tap-min); /* HIG touch target */
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--text-footnote);
    font-weight: var(--fw-medium);
    color: var(--foreground-muted);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .location-pin {
    display: block; /* kill inline-SVG baseline gap so flex-center is exact */
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--foreground-muted);
  }

  .location-link:hover {
    color: var(--foreground);
    background: var(--glass-surface);
  }

  /* Override the global span rule (16px/1.5) so the label box matches the pin
     height — line-height:1 removes leading, so align-items:center is exact. */
  .location-text {
    font-size: var(--text-footnote);
    line-height: 1;
    white-space: nowrap;
  }

  /* Mobile: Allow location text to truncate gracefully */
  @media (max-width: 640px) {
    .location-link {
      font-size: 0.875rem; /* 14pt on mobile */
      max-width: 100%;
    }

    .location-text {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
</style>

<script>
  // Toggle Experience Items
  function toggleExperienceItems() {
    const hiddenItems = document.querySelectorAll('.experience-item.hidden');
    const visibleItems = document.querySelectorAll('.experience-item:not(.hidden)');
    const button = document.getElementById('load-more-experience');
    const buttonText = document.getElementById('experience-button-text');
    
    if (hiddenItems.length > 0) {
      // Show all hidden items
      hiddenItems.forEach(item => item.classList.remove('hidden'));
      buttonText.textContent = 'Show Less Experience';
      button.querySelector('span').textContent = '📋';
    } else {
      // Hide items after index 2 (show only first 3)
      const allItems = document.querySelectorAll('.experience-item');
      allItems.forEach((item, index) => {
        if (index >= 3) {
          item.classList.add('hidden');
        }
      });
      buttonText.textContent = 'Show More Experience';
      button.querySelector('span').textContent = '📋';
    }
  }

  // Toggle Project Items
  function toggleProjectItems() {
    const hiddenItems = document.querySelectorAll('.project-item.hidden');
    const visibleItems = document.querySelectorAll('.project-item:not(.hidden)');
    const button = document.getElementById('load-more-projects');
    const buttonText = document.getElementById('projects-button-text');
    
    if (hiddenItems.length > 0) {
      // Show all hidden items
      hiddenItems.forEach(item => item.classList.remove('hidden'));
      buttonText.textContent = 'Show Less Projects';
      button.querySelector('span').textContent = '🚀';
    } else {
      // Hide items after index 2 (show only first 3)
      const allItems = document.querySelectorAll('.project-item');
      allItems.forEach((item, index) => {
        if (index >= 3) {
          item.classList.add('hidden');
        }
      });
      buttonText.textContent = 'Show More Projects';
      button.querySelector('span').textContent = '🚀';
    }
  }

  // Make functions global so they can be called from onclick
  if (typeof window !== 'undefined') {
    window.toggleExperienceItems = toggleExperienceItems;
    window.toggleProjectItems = toggleProjectItems;
  }
</script>
