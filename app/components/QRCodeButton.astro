---
import LiquidGlassIcon from './LiquidGlassIcon.astro';

export interface Props {
  url: string;
  class?: string;
}

const { url, class: className } = Astro.props;

// Use local QR code images generated at build time for better performance
const qrCodeUrl = '/assets/images/qr-code-modal.png';
---

<button
  class={`apple-contact-badge group ${className || ''}`}
  onclick={`showQRModal('${qrCodeUrl}', '${url}')`}
  type="button"
  aria-label="Show QR code to share this resume"
  data-contact-type="qr-share"
  data-contact-value={url}
>
  <div class="apple-contact-icon">
    <LiquidGlassIcon name="heroicons:qr-code" size={20} variant="subtle" />
  </div>
  <div class="apple-contact-info">
    <div class="apple-contact-label">
      Share via QR
    </div>
    <div class="apple-contact-value">
      Scan to open on phone
    </div>
  </div>
</button>

<!-- QR Modal -->
<div id="qr-modal" class="qr-modal" onclick="closeQRModal()">
  <div class="qr-content" onclick="event.stopPropagation()">
    <div class="qr-header">
      <h3>Scan to View Resume</h3>
      <button onclick="closeQRModal()" class="close-btn">&times;</button>
    </div>
    <div class="qr-image-container">
      <img id="qr-image" src="" alt="QR Code" />
    </div>
    <div class="qr-url" id="qr-url"></div>
    <div class="qr-footer">
      <p>Scan with your phone camera or QR reader</p>
    </div>
  </div>
</div>

<style>
  /* Apple-Style Contact Badge Components - Consistent with ContactButton.astro.
     Material now draws from the shared liquid-glass tokens (global.css) instead
     of raw literals, so this badge matches the migrated .glass-card surfaces and
     flips light/dark automatically via the --glass-* overrides. */
  .apple-contact-badge {
    display: flex;
    align-items: center;
    padding: clamp(var(--space-3), 1.5vw, var(--space-4)) clamp(var(--space-4), 2vw, var(--space-5));
    background: var(--glass-surface);
    backdrop-filter: var(--glass-filter-sm);
    -webkit-backdrop-filter: var(--glass-filter-sm);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius); /* Apple HIG rounded corners */
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--glass-shadow);
    min-width: 0; /* Allow flex shrinkage */
    width: 100%; /* Full width for better text space */
    box-sizing: border-box;
    cursor: pointer;
    /* Smart text handling - prevents awkward line breaks */
    container-type: inline-size; /* Enable container queries */
  }

  .apple-contact-badge:hover {
    background: var(--glass-hover-bg);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15); /* hover elevation — no token */
  }

  .apple-contact-icon {
    width: 44px; /* liquid-glass icon material box */
    height: 44px;
    /* Liquid Glass Background - Matching LiquidGlassIcon component (decorative
       gradient + white highlight border have no single token; kept literal). */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0.1) 100%
    );
    backdrop-filter: var(--glass-filter);
    -webkit-backdrop-filter: var(--glass-filter);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--glass-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: var(--space-3);
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    /* Enhanced shadows for depth */
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .apple-contact-badge:hover .apple-contact-icon {
    transform: translateY(-2px) scale(1.05);
    /* Enhanced lighting on hover */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(255, 255, 255, 0.15) 100%
    );
    /* Intensified shadows and highlights */
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 2px 0 rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .apple-contact-info {
    flex: 1;
    min-width: 0; /* Allows text truncation */
    overflow: hidden; /* Prevent content overflow */
  }

  .apple-contact-label {
    font-size: var(--text-caption); /* 13px caption — smallest allowed */
    font-weight: var(--fw-medium);
    line-height: var(--lh-heading);
    color: var(--foreground-muted); /* semantic secondary label (was fg + opacity) */
    margin-bottom: var(--space-1);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    white-space: nowrap; /* Prevent label wrapping */
    text-align: left; /* Prevent centering */
  }

  .apple-contact-value {
    font-size: var(--text-footnote); /* 14px */
    font-weight: var(--fw-semibold);
    line-height: var(--lh-heading);
    color: var(--foreground);
    /* Apple HIG Smart Text Handling - Responsive Approach */
    overflow-wrap: break-word;
    word-break: normal; /* Changed from break-word to prevent awkward breaks */
    hyphens: auto;
    /* Default: Single line with ellipsis */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: left; /* Prevent centering */
  }

  /* Container queries for responsive text handling */
  @container (min-width: 200px) {
    .apple-contact-value {
      white-space: normal; /* Allow wrapping on wider containers */
      overflow: visible;
      text-overflow: unset;
      word-spacing: -0.02em; /* Tighter word spacing for better fit */
    }
  }

  /* Enhanced responsive breakpoints for contact badges */
  @media (max-width: 640px) {
    .apple-contact-badge {
      padding: var(--space-3); /* Tighter on mobile */
      min-height: 60px; /* Ensure touch target (well above --tap-min) */
    }

    .apple-contact-value {
      font-size: var(--text-footnote); /* 14px on mobile */
      line-height: var(--lh-heading);
      /* Mobile: Allow controlled wrapping */
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
      hyphens: auto;
      word-break: break-word;
      /* Limit to 2 lines maximum on mobile */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  /* Dark theme: the badge material now flows from the theme-aware --glass-* tokens,
     so the old .dark badge background/border/shadow overrides are gone. Only the
     decorative liquid-glass ICON (its own white gradient + highlight, which have no
     token) still needs an explicit dark treatment. */
  :global(.dark) .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.05) 100%
    );
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 1px 0 rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.dark) .apple-contact-badge:hover .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.04) 50%,
      rgba(255, 255, 255, 0.08) 100%
    );
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 2px 0 rgba(255, 255, 255, 0.08);
  }

  .qr-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8); /* modal scrim — not a glass surface */
    backdrop-filter: blur(5px);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 999999; /* Above Netlify deploy preview (z-index: 999998) */
    overflow-y: auto; /* Allow scrolling if content is taller than viewport */
    padding: var(--space-6) 0; /* Add vertical padding for better spacing */
  }

  /* Self-contained light "QR card": intentionally white with fixed ink colors in
     BOTH themes so the QR code always scans. Geometry uses shared spacing/radius
     tokens; the white surface + text colors stay literal on purpose — theme color
     tokens would flip to dark and destroy the contrast the QR relies on. */
  .qr-content {
    background: white;
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    max-width: 400px;
    width: 90%;
    margin: auto; /* Center in scrollable container */
    text-align: center;
    position: relative;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .qr-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
  }

  .qr-header h3 {
    margin: 0;
    color: #2d3748;
    font-size: var(--text-headline);
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 2rem; /* glyph size — iconographic, no token */
    cursor: pointer;
    color: #718096;
    line-height: 1;
    /* HIG touch target — was a ~32px hit area */
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
  }

  .close-btn:hover {
    color: #2d3748;
  }

  .qr-image-container {
    margin: var(--space-5) 0;
    display: flex;
    justify-content: center;
  }

  .qr-image-container img {
    max-width: 250px;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }

  .qr-url {
    font-size: var(--text-footnote);
    color: #667eea; /* stays literal — see .qr-content note (always-white card) */
    word-break: break-all;
    margin: var(--space-4) 0;
    font-weight: var(--fw-medium);
  }

  .qr-footer {
    font-size: var(--text-caption);
    color: #718096;
    margin-top: var(--space-4);
  }

  @media (max-width: 640px) {
    .qr-content {
      padding: var(--space-5);
    }

    .qr-image-container img {
      max-width: 200px;
    }
  }
</style>

<script>
  function showQRModal(qrImageUrl, url) {
    const modal = document.getElementById('qr-modal');
    const image = document.getElementById('qr-image');
    const urlElement = document.getElementById('qr-url');

    if (modal && image && urlElement) {
      image.src = qrImageUrl;
      urlElement.textContent = url;
      modal.style.display = 'flex';

      // Prevent body scroll
      document.body.style.overflow = 'hidden';
    }
  }

  function closeQRModal() {
    const modal = document.getElementById('qr-modal');
    if (modal) {
      modal.style.display = 'none';
      // Restore body scroll
      document.body.style.overflow = '';
    }
  }

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeQRModal();
    }
  });

  // Make functions global so they can be called from onclick
  if (typeof window !== 'undefined') {
    window.showQRModal = showQRModal;
    window.closeQRModal = closeQRModal;
  }
</script>
