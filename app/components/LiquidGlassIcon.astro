---
import { Icon } from 'astro-icon/components';

export interface Props {
  name: string;
  size?: string | number;
  class?: string;
  variant?: 'default' | 'intense' | 'subtle';
}

const { name, size = 24, class: className = '', variant = 'default' } = Astro.props;

// Convert size to pixels if it's a number
const iconSize = typeof size === 'number' ? `${size}px` : size;
---

<div class={`liquid-glass-icon liquid-glass-icon--${variant} ${className}`}>
  <Icon name={name} size={iconSize} />
</div>

<style>
  /* Base Liquid Glass Icon Container — draws from the shared glass tokens
     (app/styles/global.css) so it renders as a smaller sibling of .glass-card.
     Dark theme is handled entirely by the token .dark overrides, so no
     component-level .dark rules are needed. */
  .liquid-glass-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--glass-radius-sm);
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    /* Liquid Glass material (single consolidated recipe) */
    background: var(--glass-surface);

    /* Apple's signature blur + saturation */
    backdrop-filter: var(--glass-filter);
    -webkit-backdrop-filter: var(--glass-filter);

    /* Depth shadow (legible dark border in light, luminous in dark) */
    box-shadow: var(--glass-shadow);
    border: 1px solid var(--glass-border);

    /* Container Sizing — fixed chip that comfortably exceeds --tap-min (44px) */
    width: 48px;
    height: 48px;
  }

  /* Icon Styling - currentColor for native theming */
  .liquid-glass-icon :global(svg) {
    color: var(--foreground, currentColor);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.1));
  }

  /* Hover Effects - Dynamic Lighting Response (mirrors .glass-card:hover) */
  .liquid-glass-icon:hover {
    transform: translateY(-2px) scale(1.05);
    background: var(--glass-hover-bg);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .liquid-glass-icon:hover :global(svg) {
    color: var(--link-color, var(--foreground, currentColor));
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
  }

  /* Variant: Default */
  .liquid-glass-icon--default {
    /* Standard configuration - already applied above */
  }

  /* Variant: Intense - stronger surface (matches .glass-card--intense) */
  .liquid-glass-icon--intense {
    background: var(--glass-surface-strong);
  }

  /* Variant: Subtle - lighter blur (matches .glass-card--subtle) */
  .liquid-glass-icon--subtle {
    backdrop-filter: var(--glass-filter-sm);
    -webkit-backdrop-filter: var(--glass-filter-sm);
  }

  /* Accessibility: Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .liquid-glass-icon {
      transition: none;
    }

    .liquid-glass-icon:hover {
      transform: none;
    }
  }
</style>