---
// AI Chat Hero - the primary interface of the resume site (ChatGPT-style).
// Talks to the resume-ai API (Cloudflare Worker) via plain JSON fetch (no streaming).
// Replaces the old corner FAB ChatWidget: ONE chat surface, mounted as the
// first viewport of index.astro. Resume content lives below (#resume-content).

// Same build-time URL used by index.astro's PDF affordances (Astro.site already
// includes the GitHub Pages /resume-as-code base path when GITHUB_PAGES=true).
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'http://localhost:4321';

// Card strings are KV cache keys, prewarmed on every deploy. Single source of
// truth: app/data/chat-cards.json (shared with the worker + seed script) —
// edit labels/answers THERE, never here.
import chatCards from '../data/chat-cards.json';
const promptCards = chatCards.cards.map((card) => card.q);
---

<section id="chat-hero" class="ch-hero" aria-label="AI resume assistant">
  <div class="ch-inner">
    <!-- Greeting (hero mode only; the inline script below rotates the line
         BEFORE first paint — no post-load text flash) -->
    <div id="chat-intro" class="ch-intro">
      <p id="chat-greeting" class="ch-greeting">Hi &mdash; I'm Rafael's AI resume. Ask me anything.</p>
      <script is:inline>
        // Runs during HTML parsing, before paint: swap in a rotating greeting
        // variant with zero flash. Every variant self-introduces as the AI resume.
        (function () {
          var g = document.getElementById('chat-greeting');
          if (!g) return;
          var lines = [
            "Hi — I'm Rafael's AI resume. Ask me anything.",
            "I'm Rafael's AI resume — the version you can interview.",
            "I'm Rafael's AI resume — 10+ years of platform engineering.",
            "I'm Rafael's AI resume — English or português, ask away.",
          ];
          g.textContent = lines[Math.floor(Math.random() * lines.length)];
        })();
      </script>
      <p class="ch-disclosure">Everything I say comes from the real resume &mdash; the full version and PDF downloads are one scroll below.</p>
    </div>

    <!-- Conversation thread (conversation mode only) -->
    <div id="chat-thread" class="ch-thread" hidden>
      <div class="ch-thread-header">
        <span class="ch-thread-title">Chat with my resume</span>
        <div class="ch-thread-actions">
          <button id="chat-new" class="ch-text-btn" type="button">New chat</button>
          <button id="chat-clear" class="ch-icon-btn" type="button" aria-label="Clear conversation">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
            <span id="chat-clear-hint" class="ch-clear-hint" hidden>Tap again</span>
          </button>
        </div>
      </div>
      <div id="chat-messages" class="ch-messages" role="log" aria-live="polite" aria-label="Chat messages"></div>
    </div>

    <!-- Example prompts — cache-prewarmed strings. Placed ABOVE the input in
         the DOM so keyboard tab order matches the visual order in BOTH hero
         (2×2 grid) and conversation (compact chip row) modes; they never
         disappear. The canonical question lives in data-q: it is the KV cache
         key, so it must never be derived from rendered textContent. -->
    <div id="chat-cards" class="ch-cards">
      {promptCards.map((prompt) => (
        <button type="button" class="ch-card" data-q={prompt}>{prompt}</button>
      ))}
    </div>

    <div id="chat-cooldown" class="ch-cooldown" hidden></div>

    <!-- Input pill (always visible, anchored under the cards) -->
    <form id="chat-form" class="ch-form" autocomplete="off">
      <input
        id="chat-input"
        class="ch-input"
        type="text"
        maxlength="500"
        placeholder="Ask me about my experience..."
        aria-label="Type your question"
      />
      <button id="chat-send" class="ch-send" type="submit" aria-label="Send message">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      </button>
    </form>

    <!-- Secondary actions -->
    <div class="ch-actions">
      <a
        id="chat-pdf-link"
        class="ch-action-link"
        href={`${siteUrl}/pdf-screen`}
        target="_blank"
        rel="noopener noreferrer"
        data-pdf-type="screen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="15" height="15" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Get the PDF
      </a>
      <span class="ch-action-sep" aria-hidden="true">&middot;</span>
      <a id="chat-skip" class="ch-action-link" href="#resume-content">&darr; Or read the full resume</a>
    </div>
  </div>

  <!-- Scroll cue -->
  <button id="chat-scroll-cue" class="ch-scroll-cue" type="button" aria-label="Scroll to full resume">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="26" height="26" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>
</section>

<!-- Back-to-chat pill (visible only when the hero is scrolled out of view) -->
<button id="chat-pill" class="ch-pill" type="button" hidden aria-label="Back to chat">
  &uarr; Chat
</button>

<style is:global>
  /* Chat hero - global styles (message elements are created dynamically via JS,
     so Astro scoped styles would not apply). All selectors are ch- prefixed. */

  .ch-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* top padding keeps the greeting clear of the fixed theme toggle (top-right, z-50) */
    padding: var(--space-10) var(--space-4) var(--space-10);
    color: var(--foreground);
    overflow: hidden;
  }

  /* Ambient color fields behind the glass — liquid glass reads as glass only
     when there is something beneath it to blur and refract (HIG: the material
     takes on colors from the content behind it). */
  .ch-hero::before,
  .ch-hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: -1;
  }

  .ch-hero::before {
    width: 44rem;
    height: 44rem;
    top: -12rem;
    left: -10rem;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.28), transparent 65%);
  }

  .ch-hero::after {
    width: 38rem;
    height: 38rem;
    bottom: -10rem;
    right: -8rem;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 65%);
  }

  .dark .ch-hero::before {
    background: radial-gradient(circle, rgba(59, 130, 246, 0.18), transparent 65%);
  }

  .dark .ch-hero::after {
    background: radial-gradient(circle, rgba(168, 85, 247, 0.16), transparent 65%);
  }

  .ch-inner {
    width: 100%;
    max-width: 680px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
  }

  /* Entrance animation (fade-up, staggered) */
  @keyframes ch-fade-up {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ch-intro,
  .ch-thread,
  .ch-form,
  .ch-cards,
  .ch-actions {
    animation: ch-fade-up 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .ch-form { animation-delay: 0.1s; }
  .ch-cards { animation-delay: 0.2s; }
  .ch-actions { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .ch-intro,
    .ch-thread,
    .ch-form,
    .ch-cards,
    .ch-actions {
      animation: none;
    }
  }

  /* Greeting */
  .ch-intro {
    text-align: center;
  }

  .ch-greeting {
    font-size: var(--text-title-1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-title);
    line-height: var(--lh-display);
    text-wrap: balance;
    margin: 0;
  }

  .ch-disclosure {
    margin: var(--space-4) 0 0;
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-label);
    opacity: 0.6;
  }

  /* Conversation mode: greeting collapses, thread appears. The suggestion
     cards NEVER disappear — they become a compact chip row. DOM order already
     places them directly above the input (thread → cards → input), so no flex
     `order` overrides are needed and keyboard tab order matches the layout. */
  .ch-hero.ch-conv .ch-intro,
  .ch-hero.ch-conv .ch-scroll-cue {
    display: none;
  }

  .ch-hero.ch-conv .ch-cards {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: var(--space-2);
    padding-bottom: 2px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ch-hero.ch-conv .ch-cards::-webkit-scrollbar {
    display: none;
  }

  .ch-hero.ch-conv .ch-card {
    flex: 0 0 auto;
    max-width: 75vw;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-caption);
    box-shadow: none;
  }

  .ch-hero.ch-conv .ch-card:hover:not(:disabled) {
    transform: none;
  }

  /* Already-asked chip: dimmed but still tappable (asking again is a free
     cache hit) */
  .ch-card.ch-asked {
    opacity: 0.55;
  }

  /* Thread */
  .ch-thread {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    min-height: 0;
    border-radius: var(--glass-radius);
    overflow: hidden;
    background: var(--glass-surface);
    backdrop-filter: var(--glass-filter);
    -webkit-backdrop-filter: var(--glass-filter);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .ch-thread[hidden] {
    display: none;
  }

  .ch-thread-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--glass-border);
    flex-shrink: 0;
  }

  .ch-thread-title {
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    opacity: 0.8;
  }

  .ch-thread-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .ch-text-btn {
    background: none;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-caption);
    font-weight: var(--fw-medium);
    line-height: var(--lh-body);
    color: inherit;
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  .ch-text-btn:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.05);
  }

  .dark .ch-text-btn:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .ch-icon-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-1);
    cursor: pointer;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  .ch-icon-btn:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.06);
  }

  .dark .ch-icon-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .ch-icon-btn.ch-armed,
  .ch-text-btn.ch-armed {
    color: #dc2626;
    opacity: 1;
  }

  .ch-clear-hint {
    font-size: var(--text-caption);
    font-weight: var(--fw-semibold);
  }

  /* Message list: scrolls internally so the input pill stays visible */
  .ch-messages {
    overflow-y: auto;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-height: 160px;
    max-height: calc(100vh - 23rem);
    max-height: calc(100dvh - 23rem);
    overscroll-behavior: contain;
  }

  .ch-row {
    display: flex;
    flex-direction: column;
    max-width: 85%;
  }

  .ch-row.ch-user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .ch-row.ch-assistant {
    align-self: flex-start;
    align-items: flex-start;
  }

  .ch-bubble {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-body); /* messages are primary reading content — 16px floor */
    line-height: var(--lh-body);
    overflow-wrap: break-word;
    word-break: break-word;
    white-space: normal;
  }

  .ch-user .ch-bubble {
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    border-bottom-right-radius: 6px;
  }

  .ch-assistant .ch-bubble {
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom-left-radius: 6px;
  }

  .dark .ch-assistant .ch-bubble {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .ch-bubble a {
    color: var(--link-color);
    text-decoration: underline;
  }

  .ch-error .ch-bubble {
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.2);
  }

  /* Typing indicator */
  .ch-typing .ch-bubble {
    display: flex;
    gap: var(--space-1);
    align-items: center;
    padding: var(--space-3) var(--space-4);
  }

  .ch-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.4;
    animation: ch-blink 1.2s infinite ease-in-out;
  }

  .ch-dot:nth-child(2) { animation-delay: 0.2s; }
  .ch-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes ch-blink {
    0%, 80%, 100% { opacity: 0.25; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-3px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ch-dot { animation: none; opacity: 0.7; }
  }

  /* Feedback */
  .ch-feedback {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .ch-feedback-btn {
    background: none;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-caption);
    line-height: var(--lh-body);
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 0.2s ease, transform 0.2s ease;
    color: inherit;
  }

  .ch-feedback-btn:hover {
    opacity: 1;
    transform: scale(1.08);
  }

  .ch-feedback-thanks {
    font-size: var(--text-caption);
    opacity: 0.6;
    margin-top: var(--space-1);
  }

  /* Retry affordance under a failed/interrupted turn */
  .ch-retry-row {
    margin-top: var(--space-1);
  }

  .ch-retry-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-caption);
    font-weight: var(--fw-medium);
    line-height: var(--lh-body);
    color: inherit;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .ch-retry-btn:hover {
    opacity: 1;
    transform: translateY(-1px);
    background: rgba(0, 0, 0, 0.05);
  }

  .dark .ch-retry-btn:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* One-time "full resume is below" hint row — quieter than a real reply */
  .ch-hint .ch-bubble {
    background: none;
    border: none;
    padding: var(--space-1) var(--space-4);
    font-size: var(--text-caption);
    opacity: 0.65;
  }

  /* Cooldown notice */
  .ch-cooldown {
    width: 100%;
    max-width: 640px;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-caption);
    line-height: var(--lh-body);
    color: #b45309;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  .dark .ch-cooldown {
    color: #fbbf24;
  }

  .ch-cooldown[hidden] {
    display: none;
  }

  /* Input pill */
  .ch-form {
    width: 100%;
    max-width: 640px;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-5);
    border-radius: var(--glass-radius-pill);
    background: var(--glass-surface-strong);
    backdrop-filter: var(--glass-filter);
    -webkit-backdrop-filter: var(--glass-filter);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .ch-form:focus-within {
    border-color: rgba(37, 99, 235, 0.5);
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.14), 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .dark .ch-form:focus-within {
    border-color: rgba(144, 205, 244, 0.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 0 3px rgba(144, 205, 244, 0.18);
  }

  .ch-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    padding: var(--space-3) 0;
    font-size: var(--text-body); /* same body size as the message bubbles */
    color: inherit;
  }

  .ch-input::placeholder {
    color: inherit;
    opacity: 0.5;
  }

  .ch-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ch-send {
    width: var(--tap-min);
    height: var(--tap-min);
    flex-shrink: 0;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .ch-send:hover:not(:disabled) {
    transform: scale(1.06);
  }

  .ch-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Example prompt cards */
  .ch-cards {
    width: 100%;
    max-width: 640px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .ch-card {
    background: var(--glass-bg, rgba(255, 255, 255, 0.1));
    backdrop-filter: var(--glass-filter-sm);
    -webkit-backdrop-filter: var(--glass-filter-sm);
    border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.2));
    border-radius: var(--glass-radius-sm);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-footnote);
    line-height: var(--lh-body);
    text-align: left;
    color: inherit;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ch-card:hover:not(:disabled) {
    background: var(--glass-hover-bg, rgba(255, 255, 255, 0.15));
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .ch-card:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 480px) {
    .ch-cards {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .ch-card {
      padding: var(--space-2) var(--space-3);
      font-size: var(--text-caption);
    }
  }

  /* Secondary actions */
  .ch-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-caption);
  }

  .ch-action-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: inherit;
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 0.2s ease;
  }

  .ch-action-link:hover {
    opacity: 1;
  }

  .ch-action-sep {
    opacity: 0.4;
  }

  /* Scroll cue */
  .ch-scroll-cue {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    background: none;
    border: none;
    padding: var(--space-2);
    color: inherit;
    opacity: 0.45;
    cursor: pointer;
    transform: translateX(-50%);
    animation: ch-bob 2.4s ease-in-out infinite;
    transition: opacity 0.2s ease;
  }

  .ch-scroll-cue:hover {
    opacity: 0.9;
  }

  @keyframes ch-bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ch-scroll-cue { animation: none; }
  }

  /* Back-to-chat pill */
  .ch-pill {
    position: fixed;
    bottom: var(--space-5);
    right: var(--space-5);
    z-index: 999990; /* above content, below QR modal (999999) */
    border: 1px solid rgba(37, 99, 235, 0.3);
    border-radius: var(--radius-pill);
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    font-size: var(--text-footnote);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35);
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s ease;
  }

  .ch-pill:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 12px 32px rgba(37, 99, 235, 0.45);
  }

  .ch-pill[hidden] {
    display: none;
  }

  /* Visible focus rings */
  .ch-card:focus-visible,
  .ch-send:focus-visible,
  .ch-icon-btn:focus-visible,
  .ch-text-btn:focus-visible,
  .ch-feedback-btn:focus-visible,
  .ch-retry-btn:focus-visible,
  .ch-action-link:focus-visible,
  .ch-scroll-cue:focus-visible,
  .ch-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Small screens: tighter hero padding, taller thread allowance */
  @media (max-width: 640px) {
    .ch-hero {
      padding: var(--space-10) var(--space-4) var(--space-8);
    }

    .ch-messages {
      max-height: calc(100vh - 20rem);
      max-height: calc(100dvh - 20rem);
    }
  }
</style>

<script>
  // localhost AND LAN mobile testing (`make get-lan-ip` → private IP) both
  // target a local `npm run worker:dev` on :8787; everything else hits prod.
  const CHAT_IS_DEV_HOST =
    window.location.hostname === 'localhost' ||
    window.location.hostname === '127.0.0.1' ||
    /^(?:192\.168\.|10\.|172\.(?:1[6-9]|2\d|3[01])\.)/.test(window.location.hostname);
  const CHAT_API_BASE = CHAT_IS_DEV_HOST
    ? 'http://' + window.location.hostname + ':8787'
    : 'https://resume.rafaracing.com.br';

  const CHAT_STORAGE_KEY = 'resume_chat_history_v1';
  const CHAT_COOLDOWN_KEY = 'resume_chat_cooldown_until';
  const CHAT_MAX_STORED = 20;
  const CHAT_EXPIRY_MS = 30 * 24 * 60 * 60 * 1000; // 30 days
  const CHAT_COOLDOWN_MS = 5 * 60 * 1000; // default (rate limit) — server retryAfterSeconds wins when present
  const CHAT_QUOTA_COOLDOWN_MS = 60 * 60 * 1000; // 503 = daily AI quota gone; retrying in minutes is pointless
  const CHAT_TIMEOUT_MS = 45 * 1000; // must exceed the worker's worst-case fallback chain (~35s)

  // Autofocus / refocus only on devices with a precise pointer — never pop the
  // keyboard on mobile.
  const CHAT_POINTER_FINE = window.matchMedia('(pointer: fine)').matches;
  const CHAT_REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const CHAT_SCROLL_BEHAVIOR = CHAT_REDUCED_MOTION ? 'instant' : 'smooth';

  // In-memory conversation state (mirrors localStorage)
  let chatMessages = [];
  let chatInFlight = false;
  let clearArmed = false;
  let clearArmTimer = null;
  let cooldownTimer = null;
  // Card "typed into the chat bar" animation state (see askCard)
  let cardTypingActive = false;
  let cardTypeTimer = null;

  const heroEl = document.getElementById('chat-hero');
  const threadEl = document.getElementById('chat-thread');
  const messagesEl = document.getElementById('chat-messages');
  const cardsEl = document.getElementById('chat-cards');
  const cooldownEl = document.getElementById('chat-cooldown');
  const formEl = document.getElementById('chat-form');
  const inputEl = document.getElementById('chat-input');
  const sendEl = document.getElementById('chat-send');
  const clearEl = document.getElementById('chat-clear');
  const clearHintEl = document.getElementById('chat-clear-hint');
  const newChatEl = document.getElementById('chat-new');
  const skipEl = document.getElementById('chat-skip');
  const scrollCueEl = document.getElementById('chat-scroll-cue');
  const pillEl = document.getElementById('chat-pill');

  function trackEvent(eventName, props) {
    try {
      if (window.dataLayer && typeof window.dataLayer.push === 'function') {
        window.dataLayer.push(Object.assign({ event: eventName }, props || {}));
      }
    } catch (_e) {
      /* analytics must never break the chat */
    }
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Autolink ONLY exact allowed URL prefixes found in already-escaped text.
  // Runs on escaped text: '&' only appears as entities, so '&amp;' is allowed
  // inside URLs while '&quot;'/'&#39;' terminate them.
  function linkifyEscaped(escaped) {
    const pattern = /(https:\/\/(?:www\.linkedin\.com|github\.com|resume\.rafaracing\.com\.br)\/(?:[^\s<&]|&amp;)*|mailto:(?:[^\s<&]|&amp;)+)/g;
    return escaped.replace(pattern, function (match) {
      let url = match;
      let trailing = '';
      while (/[.,!?;:)\]]$/.test(url)) {
        trailing = url.slice(-1) + trailing;
        url = url.slice(0, -1);
      }
      if (!url) return match;
      return (
        '<a href="' + url + '" target="_blank" rel="noopener noreferrer">' + url + '</a>' + trailing
      );
    });
  }

  function renderText(text) {
    return linkifyEscaped(escapeHtml(text)).replace(/\n/g, '<br>');
  }

  function loadHistory() {
    try {
      const raw = localStorage.getItem(CHAT_STORAGE_KEY);
      if (!raw) return [];
      const data = JSON.parse(raw);
      if (!data || !Array.isArray(data.messages)) return [];
      if (typeof data.savedAt !== 'number' || Date.now() - data.savedAt > CHAT_EXPIRY_MS) {
        localStorage.removeItem(CHAT_STORAGE_KEY);
        return [];
      }
      return data.messages.filter(function (m) {
        return m && (m.role === 'user' || m.role === 'assistant') && typeof m.content === 'string';
      });
    } catch (_e) {
      return [];
    }
  }

  function saveHistory() {
    try {
      const trimmed = chatMessages.slice(-CHAT_MAX_STORED);
      localStorage.setItem(CHAT_STORAGE_KEY, JSON.stringify({ messages: trimmed, savedAt: Date.now() }));
    } catch (_e) {
      /* storage may be unavailable (private mode) */
    }
  }

  function scrollToBottom() {
    if (messagesEl) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // Hero morph: greeting + cards collapse, thread appears above the input.
  function enterConversationMode() {
    if (!heroEl.classList.contains('ch-conv')) {
      heroEl.classList.add('ch-conv');
      threadEl.hidden = false;
    }
  }

  function exitConversationMode() {
    heroEl.classList.remove('ch-conv');
    threadEl.hidden = true;
  }

  function appendBubble(role, content, options) {
    const opts = options || {};
    const row = document.createElement('div');
    row.className = 'ch-row ch-' + role + (opts.error ? ' ch-error' : '');
    const bubble = document.createElement('div');
    bubble.className = 'ch-bubble';
    bubble.innerHTML = renderText(content);
    row.appendChild(bubble);
    if (role === 'assistant' && opts.feedback) {
      row.appendChild(buildFeedbackBar(opts.question || '', content));
    }
    messagesEl.appendChild(row);
    scrollToBottom();
    return row;
  }

  function buildFeedbackBar(question, reply) {
    const bar = document.createElement('div');
    bar.className = 'ch-feedback';

    function makeBtn(verdict, label, emoji) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ch-feedback-btn';
      btn.setAttribute('aria-label', label);
      btn.textContent = emoji;
      btn.addEventListener('click', function () {
        sendFeedback(verdict, question, reply);
        const thanks = document.createElement('span');
        thanks.className = 'ch-feedback-thanks';
        thanks.textContent = 'Thanks for the feedback';
        bar.replaceWith(thanks);
        trackEvent('chat_feedback');
      });
      return btn;
    }

    bar.appendChild(makeBtn('up', 'Good response', '\u{1F44D}'));
    bar.appendChild(makeBtn('down', 'Bad response', '\u{1F44E}'));
    return bar;
  }

  function sendFeedback(verdict, question, reply) {
    try {
      fetch(CHAT_API_BASE + '/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          verdict: verdict,
          question: String(question).slice(0, 500),
          reply: String(reply).slice(0, 2000),
        }),
      }).catch(function () {
        /* fire-and-forget */
      });
    } catch (_e) {
      /* never break UI on feedback */
    }
  }

  function showTyping() {
    const row = document.createElement('div');
    row.className = 'ch-row ch-assistant ch-typing';
    row.id = 'chat-typing';
    row.setAttribute('role', 'status');
    row.setAttribute('aria-live', 'polite');
    row.setAttribute('aria-label', 'Assistant is typing');
    const bubble = document.createElement('div');
    bubble.className = 'ch-bubble';
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('span');
      dot.className = 'ch-dot';
      bubble.appendChild(dot);
    }
    row.appendChild(bubble);
    messagesEl.appendChild(row);
    scrollToBottom();
  }

  function hideTyping() {
    const typing = document.getElementById('chat-typing');
    if (typing) typing.remove();
  }

  function setBusy(busy) {
    chatInFlight = busy;
    updateInputState();
  }

  // In-memory mirror so the cooldown still holds when sessionStorage is
  // unavailable (Safari lockdown / storage-blocked browsers).
  let memCooldownUntil = 0;

  function cooldownRemainingMs() {
    let stored = 0;
    try {
      stored = parseInt(sessionStorage.getItem(CHAT_COOLDOWN_KEY) || '0', 10);
    } catch (_e) {
      /* storage unavailable — memCooldownUntil covers us */
    }
    return Math.max(0, stored - Date.now(), memCooldownUntil - Date.now());
  }

  // 'rate' = short high-demand pause; 'quota' = daily AI limit, counts down to
  // the 00:00 UTC reset.
  var cooldownReason = 'rate';

  function startCooldown(durationMs, reason) {
    cooldownReason = reason === 'quota' ? 'quota' : 'rate';
    const until = Date.now() + (durationMs || CHAT_COOLDOWN_MS);
    memCooldownUntil = until;
    try {
      sessionStorage.setItem(CHAT_COOLDOWN_KEY, String(until));
      sessionStorage.setItem(CHAT_COOLDOWN_KEY + ':reason', cooldownReason);
    } catch (_e) {
      /* storage unavailable — memCooldownUntil covers us */
    }
    refreshCooldownUI();
  }

  // ms -> "3h 12m" / "12m 05s" / "45s"
  function fmtCountdown(ms) {
    const total = Math.max(0, Math.round(ms / 1000));
    const h = Math.floor(total / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = total % 60;
    if (h > 0) return h + 'h ' + m + 'm';
    if (m > 0) return m + 'm ' + String(s).padStart(2, '0') + 's';
    return s + 's';
  }

  function refreshCooldownUI() {
    if (cooldownTimer) {
      clearTimeout(cooldownTimer);
      cooldownTimer = null;
    }
    const remaining = cooldownRemainingMs();
    if (remaining > 0) {
      let reason = cooldownReason;
      try {
        reason = sessionStorage.getItem(CHAT_COOLDOWN_KEY + ':reason') || cooldownReason;
      } catch (_e) {
        /* use in-memory reason */
      }
      if (reason === 'quota') {
        cooldownEl.textContent =
          "Daily AI limit reached — I'm back in " + fmtCountdown(remaining) + ' (resets 00:00 UTC).';
      } else {
        cooldownEl.textContent =
          "Getting a lot of questions right now — back in " + fmtCountdown(remaining) + '.';
      }
      cooldownEl.hidden = false;
      // Tick every second in the final 2 min for a live feel; every 30s before.
      const next = remaining > 120000 ? 30000 : 1000;
      cooldownTimer = setTimeout(refreshCooldownUI, Math.min(remaining, next));
    } else {
      cooldownEl.hidden = true;
      // Input may have just been re-enabled — let the placeholder cycle again.
      scheduleTypewriterRestart();
    }
    updateInputState();
  }

  function updateInputState() {
    const coolingDown = cooldownRemainingMs() > 0;
    const disabled = chatInFlight || coolingDown;
    inputEl.disabled = disabled;
    // Send is also locked while a card is being "typed" into the input, so a
    // click/Enter mid-animation cannot fire a partial send that races the
    // auto-send at the end of the animation (double send / wedged input). The
    // input itself stays enabled so a keypress can still take over the text.
    sendEl.disabled = disabled || cardTypingActive;
    const cards = cardsEl.querySelectorAll('.ch-card');
    for (let i = 0; i < cards.length; i++) cards[i].disabled = disabled || cardTypingActive;
  }

  function buildApiHistory(msgs) {
    // Last 4 exchanged messages, each trimmed to 400 chars (contract: max 6 x 400)
    return (msgs || chatMessages).slice(-4).map(function (m) {
      return { role: m.role, content: m.content.slice(0, 400) };
    });
  }

  // A "Retry" affordance under a failed/interrupted turn. Re-runs inference for
  // a question that is ALREADY in the thread — the antidote to the dead-end
  // where a dropped answer leaves the visitor stranded on their own message.
  function appendRetryRow(question) {
    const row = document.createElement('div');
    row.className = 'ch-row ch-assistant ch-retry-row';
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'ch-retry-btn';
    btn.innerHTML =
      '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="14" height="14" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" /></svg><span>Retry</span>';
    btn.addEventListener('click', function (e) {
      if (chatInFlight || cooldownRemainingMs() > 0) return;
      // Keyboard activation (e.detail === 0): removing this row drops focus to
      // body, and runInference only re-homes focus on precise pointers — so
      // re-home it here for coarse-pointer + hardware-keyboard users.
      var keyboardActivated = e && e.detail === 0;
      row.remove();
      if (keyboardActivated) inputEl.focus({ preventScroll: true });
      resendMessage(question);
    });
    row.appendChild(btn);
    messagesEl.appendChild(row);
    scrollToBottom();
  }

  async function sendMessage(text, source, opts) {
    const message = String(text || '').trim().slice(0, 500);
    // cardTypingActive guard: the only legitimate send during a card animation
    // is the auto-send at its end, which clears cardTypingActive (via
    // cancelCardTyping) BEFORE calling here. Any other send while typing is a
    // stray race and is dropped.
    if (!message || chatInFlight || cardTypingActive || cooldownRemainingMs() > 0) return;

    // Suggestion cards are self-contained canned questions with curated,
    // context-free answers seeded in KV. Sending them history-LESS makes the
    // worker serve them from that ~400-day cache (instant, zero neurons,
    // survives the daily quota) even mid-conversation — the worker only
    // reads/writes its answer cache when history is empty. Typed follow-ups
    // keep the conversation history.
    const history = opts && opts.noHistory ? [] : buildApiHistory(chatMessages);
    chatMessages.push({ role: 'user', content: message });
    saveHistory();
    enterConversationMode();
    appendBubble('user', message);
    inputEl.value = '';
    trackEvent('chat_message_sent', { source: source === 'card' ? 'card' : 'typed' });

    await runInference(message, history);
  }

  // Re-run inference for a message already shown in the thread (retry / reload
  // recovery). No new user bubble; the trailing user turn is excluded from the
  // history sent to the API so it is not duplicated.
  async function resendMessage(message) {
    if (!message || chatInFlight || cooldownRemainingMs() > 0) return;
    const priorTurns =
      chatMessages.length && chatMessages[chatMessages.length - 1].role === 'user'
        ? chatMessages.slice(0, -1)
        : chatMessages;
    trackEvent('chat_message_retried');
    await runInference(message, buildApiHistory(priorTurns));
  }

  async function runInference(message, history) {
    setBusy(true);
    showTyping();

    const controller = new AbortController();
    const timeoutId = setTimeout(function () {
      controller.abort();
    }, CHAT_TIMEOUT_MS);

    try {
      const res = await fetch(CHAT_API_BASE + '/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message, history: history }),
        signal: controller.signal,
      });

      if (res.status === 429 || res.status === 503) {
        let body = null;
        try {
          body = await res.json();
        } catch (_e) {
          /* non-JSON error body — fall back to defaults */
        }
        if (res.status === 429) {
          // Honor the server's window so a retry can actually succeed.
          const retryMs =
            body && typeof body.retryAfterSeconds === 'number' && body.retryAfterSeconds > 0
              ? body.retryAfterSeconds * 1000
              : CHAT_COOLDOWN_MS;
          startCooldown(retryMs, 'rate');
          appendBubble(
            'assistant',
            "I'm getting a lot of questions right now. Please try again in a few minutes.",
            { error: true }
          );
        } else {
          // 503 = daily AI quota exhausted. Count down to the exact reset the
          // server reports (resetInSeconds → 00:00 UTC), shown live below.
          const resetMs =
            body && typeof body.resetInSeconds === 'number' && body.resetInSeconds > 0
              ? body.resetInSeconds * 1000
              : CHAT_QUOTA_COOLDOWN_MS;
          startCooldown(resetMs, 'quota');
          appendBubble(
            'assistant',
            body && typeof body.error === 'string' && body.error
              ? body.error
              : 'The assistant reached its free daily AI quota. It resets at 00:00 UTC.',
            { error: true }
          );
        }
        // Cooldown UI + persistent cards are the forward path here; a Retry
        // button would only no-op while the cooldown holds.
        return;
      }

      if (!res.ok) {
        appendBubble('assistant', 'Sorry, something went wrong.', { error: true });
        appendRetryRow(message);
        return;
      }

      const data = await res.json();
      const reply = data && typeof data.reply === 'string' ? data.reply : '';
      if (!reply) {
        appendBubble('assistant', 'Sorry, I could not generate a reply.', { error: true });
        appendRetryRow(message);
        return;
      }

      chatMessages.push({ role: 'assistant', content: reply });
      saveHistory();
      appendBubble('assistant', reply, { feedback: true, question: message });
      maybeShowResumeHint();
    } catch (_e) {
      appendBubble('assistant', 'Connection issue.', { error: true });
      appendRetryRow(message);
    } finally {
      clearTimeout(timeoutId);
      hideTyping();
      setBusy(false);
      if (CHAT_POINTER_FINE && !inputEl.disabled) inputEl.focus({ preventScroll: true });
      scheduleTypewriterRestart();
    }
  }

  // One-time quiet system row after the first answer: the logs show visitors
  // never discover the classic resume/PDFs below the chat on their own.
  let resumeHintShown = false;
  function maybeShowResumeHint() {
    if (resumeHintShown) return;
    try {
      if (sessionStorage.getItem('resume_chat_hint_shown')) return;
      sessionStorage.setItem('resume_chat_hint_shown', '1');
    } catch (_e) {
      /* storage unavailable — the in-memory flag still limits to once per load */
    }
    resumeHintShown = true;
    const row = document.createElement('div');
    row.className = 'ch-row ch-assistant ch-hint';
    const bubble = document.createElement('div');
    bubble.className = 'ch-bubble';
    bubble.innerHTML =
      'Prefer to skim? The <a href="#resume-content">full resume and PDF downloads</a> are right below this chat.';
    const link = bubble.querySelector('a');
    if (link) link.addEventListener('click', scrollToResume);
    row.appendChild(bubble);
    messagesEl.appendChild(row);
    scrollToBottom();
  }

  function restoreHistory() {
    chatMessages = loadHistory();
    if (chatMessages.length === 0) return;
    enterConversationMode();
    for (let i = 0; i < chatMessages.length; i++) {
      const m = chatMessages[i];
      if (m.role === 'assistant') {
        const question = i > 0 && chatMessages[i - 1].role === 'user' ? chatMessages[i - 1].content : '';
        appendBubble('assistant', m.content, { feedback: true, question: question });
      } else {
        appendBubble('user', m.content);
      }
    }
    // Dead-end guard: a trailing USER turn with no assistant reply means the
    // last answer never arrived (network drop / tab closed mid-reply). Rather
    // than strand the visitor on their own unanswered message (the exact
    // scenario that reads as broken), offer to retry it — and if we're not in
    // a cooldown, kick the retry off automatically.
    const last = chatMessages[chatMessages.length - 1];
    if (last && last.role === 'user') {
      if (cooldownRemainingMs() > 0) {
        appendBubble('assistant', "My last answer didn't come through — tap retry when the cooldown clears.", {
          error: true,
        });
        appendRetryRow(last.content);
      } else {
        appendBubble('assistant', "Looks like my last answer didn't come through — let me try again.", {
          error: true,
        });
        resendMessage(last.content);
      }
    }
  }

  function resetClearArm() {
    clearArmed = false;
    clearEl.classList.remove('ch-armed');
    newChatEl.classList.remove('ch-armed');
    clearHintEl.hidden = true;
    if (clearArmTimer) {
      clearTimeout(clearArmTimer);
      clearArmTimer = null;
    }
  }

  function handleClearClick() {
    if (!clearArmed) {
      // First tap: arm and ask for a second tap (no native confirm dialogs)
      clearArmed = true;
      clearEl.classList.add('ch-armed');
      newChatEl.classList.add('ch-armed');
      clearHintEl.hidden = false;
      clearArmTimer = setTimeout(resetClearArm, 3000);
      return;
    }
    resetClearArm();
    chatMessages = [];
    try {
      localStorage.removeItem(CHAT_STORAGE_KEY);
    } catch (_e) {
      /* ignore */
    }
    messagesEl.innerHTML = '';
    exitConversationMode();
    // Fresh start: un-dim the suggestion cards and let the placeholder cycle again.
    const cards = cardsEl.querySelectorAll('.ch-card');
    for (let i = 0; i < cards.length; i++) cards[i].classList.remove('ch-asked');
    updateInputState();
    if (CHAT_POINTER_FINE && !inputEl.disabled) inputEl.focus({ preventScroll: true });
    scheduleTypewriterRestart();
  }

  function scrollToChatHero() {
    heroEl.scrollIntoView({ behavior: CHAT_SCROLL_BEHAVIOR, block: 'start' });
    if (!inputEl.disabled) inputEl.focus({ preventScroll: true });
    trackEvent('chat_opened');
  }

  function scrollToResume(e) {
    const target = document.getElementById('resume-content');
    if (!target) return; // fall back to native anchor behavior
    if (e && typeof e.preventDefault === 'function') e.preventDefault();
    target.scrollIntoView({ behavior: CHAT_SCROLL_BEHAVIOR, block: 'start' });
    trackEvent('chat_scroll_to_resume');
  }

  // Animated placeholder: types out example questions and deletes them, like a
  // search box, to invite input. Runs whenever the input is empty — hero AND
  // conversation mode — pausing on interaction and quietly resuming after a
  // few seconds of idle-empty input. It never stops for good (except with
  // reduced motion, where it never starts).
  var CHAT_PLACEHOLDER_BASE = inputEl ? inputEl.getAttribute('placeholder') : '';
  var CHAT_TYPED_EXAMPLES = [
    "What's your strongest skill?",
    'Tell me about Kubernetes at Uber',
    "How's your AWS experience?",
    'What was your biggest impact at Globo?',
    'Are you open to remote or contract work?',
    'Qual é sua experiência com Kubernetes?',
  ];
  var typeTimer = null;
  var typeRestartTimer = null;

  function pauseTypewriter() {
    if (typeTimer) {
      clearTimeout(typeTimer);
      typeTimer = null;
    }
    if (inputEl) inputEl.setAttribute('placeholder', CHAT_PLACEHOLDER_BASE);
    scheduleTypewriterRestart();
  }

  // Resume cycling once the input has been empty and idle for a moment.
  function scheduleTypewriterRestart() {
    clearTimeout(typeRestartTimer);
    typeRestartTimer = setTimeout(function () {
      if (
        !typeTimer &&
        inputEl &&
        inputEl.value.length === 0 &&
        !inputEl.disabled &&
        !cardTypingActive
      ) {
        startTypewriter();
      }
    }, 5000);
  }

  function startTypewriter() {
    if (CHAT_REDUCED_MOTION || !inputEl || typeTimer) return;
    var idx = Math.floor(Math.random() * CHAT_TYPED_EXAMPLES.length);
    var char = 0;
    var deleting = false;

    function tick() {
      if (inputEl.value.length > 0 || inputEl.disabled || cardTypingActive) {
        pauseTypewriter();
        return;
      }
      var phrase = CHAT_TYPED_EXAMPLES[idx];
      if (!deleting) {
        char++;
        inputEl.setAttribute('placeholder', phrase.slice(0, char));
        if (char >= phrase.length) {
          deleting = true;
          typeTimer = setTimeout(tick, 1600); // hold the full phrase
          return;
        }
        typeTimer = setTimeout(tick, 55);
      } else {
        char--;
        inputEl.setAttribute('placeholder', phrase.slice(0, char));
        if (char <= 0) {
          deleting = false;
          idx = (idx + 1) % CHAT_TYPED_EXAMPLES.length;
          typeTimer = setTimeout(tick, 350); // brief pause before next phrase
          return;
        }
        typeTimer = setTimeout(tick, 28);
      }
    }
    typeTimer = setTimeout(tick, 700);
  }

  // Card click = the question visibly typed into the chat bar, then sent.
  // Canonical string comes from data-q (it is the KV cache key — rendered
  // textContent could silently diverge and break instant answers). Any user
  // interaction with the input mid-animation cancels the auto-send and leaves
  // the text editable.
  function cancelCardTyping() {
    cardTypingActive = false;
    if (cardTypeTimer) {
      clearTimeout(cardTypeTimer);
      cardTypeTimer = null;
    }
    updateInputState();
  }

  function askCard(cardEl, keyboardActivated) {
    var question = cardEl.getAttribute('data-q') || cardEl.textContent;
    if (!question || chatInFlight || cardTypingActive || cooldownRemainingMs() > 0) return;
    cardEl.classList.add('ch-asked');
    pauseTypewriter();
    // Focus the input when there's no risk of popping a soft keyboard: a
    // precise pointer, OR a keyboard-driven activation (Enter/Space, which
    // implies a hardware keyboard even on a coarse-pointer tablet). Otherwise
    // activating a chip via keyboard would disable it and strand focus on body.
    var canFocus = CHAT_POINTER_FINE || keyboardActivated;
    if (CHAT_REDUCED_MOTION) {
      if (canFocus) inputEl.focus({ preventScroll: true });
      sendMessage(question, 'card', { noHistory: true });
      return;
    }
    cardTypingActive = true;
    updateInputState();
    if (canFocus) inputEl.focus({ preventScroll: true });
    // ~25ms/char, capped so long questions still land in about a second.
    var step = Math.max(12, Math.min(28, Math.round(900 / question.length)));
    var pos = 0;
    (function typeChar() {
      if (!cardTypingActive) return; // user took over the input — leave it editable
      pos++;
      inputEl.value = question.slice(0, pos);
      if (pos < question.length) {
        cardTypeTimer = setTimeout(typeChar, step);
      } else {
        cardTypeTimer = setTimeout(function () {
          if (!cardTypingActive) return;
          cancelCardTyping();
          sendMessage(question, 'card', { noHistory: true });
        }, 250);
      }
    })();
  }

  function initChatHero() {
    if (!heroEl || !threadEl || !messagesEl || !formEl || !inputEl) return;

    restoreHistory();
    refreshCooldownUI();
    trackEvent('chat_hero_seen');

    formEl.addEventListener('submit', function (e) {
      e.preventDefault();
      sendMessage(inputEl.value, 'typed');
    });

    // Typing pauses the animated placeholder (it resumes after idle-empty)
    // and cancels any in-flight card auto-send, leaving the text editable.
    inputEl.addEventListener('input', function () {
      if (inputEl.value.length > 0) {
        pauseTypewriter();
      } else {
        scheduleTypewriterRestart();
      }
    });
    inputEl.addEventListener('keydown', function () {
      if (cardTypingActive) cancelCardTyping();
      pauseTypewriter();
    });

    const cards = cardsEl.querySelectorAll('.ch-card');
    for (let i = 0; i < cards.length; i++) {
      cards[i].addEventListener('click', function (e) {
        // e.detail === 0 ⇒ keyboard activation (Enter/Space), not a pointer tap.
        askCard(e.currentTarget, e.detail === 0);
      });
    }

    clearEl.addEventListener('click', handleClearClick);
    newChatEl.addEventListener('click', handleClearClick);

    if (skipEl) skipEl.addEventListener('click', scrollToResume);
    if (scrollCueEl) scrollCueEl.addEventListener('click', scrollToResume);

    // Back-to-chat pill: visible only while the hero is fully out of view.
    if (pillEl && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        function (entries) {
          for (let i = 0; i < entries.length; i++) {
            pillEl.hidden = entries[i].isIntersecting;
          }
        },
        { threshold: 0 }
      );
      observer.observe(heroEl);
      pillEl.addEventListener('click', scrollToChatHero);
    }

    // Autofocus the input on desktop only (pointer: fine) — never trigger the
    // mobile keyboard on load.
    if (CHAT_POINTER_FINE && !inputEl.disabled) inputEl.focus({ preventScroll: true });

    // Animated placeholder runs in both hero and conversation mode — the
    // input pill is always visible.
    startTypewriter();
  }

  initChatHero();

  // Expose for debugging/automation
  if (typeof window !== 'undefined') {
    window.scrollToChatHero = scrollToChatHero;
  }
</script>
