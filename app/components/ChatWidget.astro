---
// AI Chat Widget - floating assistant that answers questions about this resume.
// Talks to the resume-ai API (Cloudflare Worker) via plain JSON fetch (no streaming).
---

<!-- Floating Action Button -->
<button
  id="chat-fab"
  class="cw-fab"
  type="button"
  aria-label="Ask AI about Rafael's resume"
  aria-haspopup="dialog"
  aria-expanded="false"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
  </svg>
</button>

<!-- Chat Panel -->
<div
  id="chat-panel"
  class="cw-panel"
  role="dialog"
  aria-label="AI resume assistant"
  hidden
>
  <div class="cw-header">
    <span class="cw-title">Ask AI about this resume</span>
    <div class="cw-header-actions">
      <button id="chat-clear" class="cw-icon-btn" type="button" aria-label="Clear conversation">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
        <span id="chat-clear-hint" class="cw-clear-hint" hidden>Tap again</span>
      </button>
      <button id="chat-close" class="cw-icon-btn" type="button" aria-label="Close chat">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="chat-messages" class="cw-messages" role="log" aria-live="polite" aria-label="Chat messages">
    <div class="cw-row cw-assistant cw-welcome">
      <div class="cw-bubble">
        Hi! I'm an AI assistant that can answer questions about Rafael's
        experience, skills, projects, and availability. Ask me anything about
        this resume.
      </div>
    </div>
  </div>

  <div id="chat-chips" class="cw-chips">
    <button type="button" class="cw-chip">How many years of AWS experience?</button>
    <button type="button" class="cw-chip">What is his current role?</button>
    <button type="button" class="cw-chip">Is he open to new opportunities?</button>
    <button type="button" class="cw-chip">Summarize his DevOps toolbox</button>
  </div>

  <div id="chat-cooldown" class="cw-cooldown" hidden></div>

  <form id="chat-form" class="cw-form" autocomplete="off">
    <input
      id="chat-input"
      class="cw-input"
      type="text"
      maxlength="500"
      placeholder="Ask about Rafael's experience..."
      aria-label="Type your question"
    />
    <button id="chat-send" class="cw-send" type="submit" aria-label="Send message">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
      </svg>
    </button>
  </form>
</div>

<style is:global>
  /* Chat widget - global styles (elements are created dynamically via JS,
     so Astro scoped styles would not apply). All selectors are cw- prefixed. */

  .cw-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999990; /* above content, below QR modal (999999) */
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(37, 99, 235, 0.3);
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35);
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s ease;
    animation: cw-pulse-once 1.6s cubic-bezier(0.4, 0, 0.2, 1) 1s 2;
  }

  .cw-fab:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 12px 32px rgba(37, 99, 235, 0.45);
  }

  .cw-fab[hidden] {
    display: none;
  }

  @keyframes cw-pulse-once {
    0% { box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35), 0 0 0 0 rgba(37, 99, 235, 0.5); }
    70% { box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35), 0 0 0 14px rgba(37, 99, 235, 0); }
    100% { box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35), 0 0 0 0 rgba(37, 99, 235, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cw-fab { animation: none; }
  }

  .cw-panel {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 999991;
    width: 380px;
    max-width: calc(100vw - 3rem);
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
    color: var(--foreground, #1a1a1a);
  }

  .cw-panel[hidden] {
    display: none;
  }

  .dark .cw-panel {
    background: rgba(15, 20, 25, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
  }

  .cw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .dark .cw-header {
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  .cw-title {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .cw-header-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .cw-icon-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    border-radius: 8px;
    padding: 6px;
    cursor: pointer;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  .cw-icon-btn:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.06);
  }

  .dark .cw-icon-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .cw-icon-btn.cw-armed {
    color: #dc2626;
    opacity: 1;
  }

  .cw-clear-hint {
    font-size: 0.6875rem;
    font-weight: 600;
  }

  .cw-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    min-height: 180px;
    overscroll-behavior: contain;
  }

  .cw-row {
    display: flex;
    flex-direction: column;
    max-width: 85%;
  }

  .cw-row.cw-user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .cw-row.cw-assistant {
    align-self: flex-start;
    align-items: flex-start;
  }

  .cw-bubble {
    padding: 0.625rem 0.875rem;
    border-radius: 16px;
    font-size: 0.875rem;
    line-height: 1.5;
    overflow-wrap: break-word;
    word-break: break-word;
    white-space: normal;
  }

  .cw-user .cw-bubble {
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    border-bottom-right-radius: 6px;
  }

  .cw-assistant .cw-bubble {
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom-left-radius: 6px;
  }

  .dark .cw-assistant .cw-bubble {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .cw-bubble a {
    color: #2563eb;
    text-decoration: underline;
  }

  .dark .cw-bubble a {
    color: #90cdf4;
  }

  .cw-error .cw-bubble {
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.2);
  }

  /* Typing indicator */
  .cw-typing .cw-bubble {
    display: flex;
    gap: 5px;
    align-items: center;
    padding: 0.75rem 0.875rem;
  }

  .cw-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.4;
    animation: cw-blink 1.2s infinite ease-in-out;
  }

  .cw-dot:nth-child(2) { animation-delay: 0.2s; }
  .cw-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes cw-blink {
    0%, 80%, 100% { opacity: 0.25; transform: translateY(0); }
    40% { opacity: 1; transform: translateY(-3px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cw-dot { animation: none; opacity: 0.7; }
  }

  /* Feedback */
  .cw-feedback {
    display: flex;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .cw-feedback-btn {
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 0.75rem;
    line-height: 1.4;
    cursor: pointer;
    opacity: 0.75;
    transition: opacity 0.2s ease, transform 0.2s ease;
    color: inherit;
  }

  .dark .cw-feedback-btn {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .cw-feedback-btn:hover {
    opacity: 1;
    transform: scale(1.08);
  }

  .cw-feedback-thanks {
    font-size: 0.6875rem;
    opacity: 0.6;
    margin-top: 0.25rem;
  }

  /* Suggestion chips */
  .cw-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0 1rem 0.75rem;
    flex-shrink: 0;
  }

  .cw-chips[hidden] {
    display: none;
  }

  .cw-chip {
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.25);
    border-radius: 999px;
    padding: 0.3125rem 0.75rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: #1e40af;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    text-align: left;
  }

  .dark .cw-chip {
    background: rgba(37, 99, 235, 0.18);
    border-color: rgba(96, 165, 250, 0.35);
    color: #90cdf4;
  }

  .cw-chip:hover:not(:disabled) {
    background: rgba(37, 99, 235, 0.16);
    transform: translateY(-1px);
  }

  .cw-chip:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Cooldown notice */
  .cw-cooldown {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: #b45309;
    background: rgba(245, 158, 11, 0.1);
    border-top: 1px solid rgba(245, 158, 11, 0.2);
    flex-shrink: 0;
  }

  .dark .cw-cooldown {
    color: #fbbf24;
  }

  .cw-cooldown[hidden] {
    display: none;
  }

  /* Input form */
  .cw-form {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .dark .cw-form {
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .cw-input {
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 12px;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    background: rgba(255, 255, 255, 0.7);
    color: inherit;
  }

  .dark .cw-input {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .cw-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cw-send {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .cw-send:hover:not(:disabled) {
    transform: scale(1.06);
  }

  .cw-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Visible focus rings */
  .cw-fab:focus-visible,
  .cw-icon-btn:focus-visible,
  .cw-chip:focus-visible,
  .cw-input:focus-visible,
  .cw-send:focus-visible,
  .cw-feedback-btn:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .dark .cw-fab:focus-visible,
  .dark .cw-icon-btn:focus-visible,
  .dark .cw-chip:focus-visible,
  .dark .cw-input:focus-visible,
  .dark .cw-send:focus-visible,
  .dark .cw-feedback-btn:focus-visible {
    outline-color: #90cdf4;
  }

  /* Mobile: full-width bottom sheet */
  @media (max-width: 640px) {
    .cw-panel {
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      max-width: 100%;
      max-height: 80vh;
      border-radius: 20px 20px 0 0;
    }
  }
</style>

<script>
  // localhost AND LAN mobile testing (`make get-lan-ip` → private IP) both
  // target a local `npm run worker:dev` on :8787; everything else hits prod.
  const CHAT_IS_DEV_HOST =
    window.location.hostname === 'localhost' ||
    window.location.hostname === '127.0.0.1' ||
    /^(?:192\.168\.|10\.|172\.(?:1[6-9]|2\d|3[01])\.)/.test(window.location.hostname);
  const CHAT_API_BASE = CHAT_IS_DEV_HOST
    ? 'http://' + window.location.hostname + ':8787'
    : 'https://resume.rafaracing.com.br';

  const CHAT_STORAGE_KEY = 'resume_chat_history_v1';
  const CHAT_COOLDOWN_KEY = 'resume_chat_cooldown_until';
  const CHAT_MAX_STORED = 20;
  const CHAT_EXPIRY_MS = 30 * 24 * 60 * 60 * 1000; // 30 days
  const CHAT_COOLDOWN_MS = 5 * 60 * 1000; // default (rate limit) — server retryAfterSeconds wins when present
  const CHAT_QUOTA_COOLDOWN_MS = 60 * 60 * 1000; // 503 = daily AI quota gone; retrying in minutes is pointless
  const CHAT_TIMEOUT_MS = 45 * 1000; // must exceed the worker's worst-case fallback chain (~35s)

  // In-memory conversation state (mirrors localStorage)
  let chatMessages = [];
  let chatInFlight = false;
  let clearArmed = false;
  let clearArmTimer = null;
  let cooldownTimer = null;

  const fab = document.getElementById('chat-fab');
  const panel = document.getElementById('chat-panel');
  const messagesEl = document.getElementById('chat-messages');
  const chipsEl = document.getElementById('chat-chips');
  const cooldownEl = document.getElementById('chat-cooldown');
  const formEl = document.getElementById('chat-form');
  const inputEl = document.getElementById('chat-input');
  const sendEl = document.getElementById('chat-send');
  const clearEl = document.getElementById('chat-clear');
  const clearHintEl = document.getElementById('chat-clear-hint');
  const closeEl = document.getElementById('chat-close');

  function trackEvent(eventName) {
    try {
      if (window.dataLayer && typeof window.dataLayer.push === 'function') {
        window.dataLayer.push({ event: eventName });
      }
    } catch (_e) {
      /* analytics must never break the widget */
    }
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Autolink ONLY exact allowed URL prefixes found in already-escaped text.
  // Runs on escaped text: '&' only appears as entities, so '&amp;' is allowed
  // inside URLs while '&quot;'/'&#39;' terminate them.
  function linkifyEscaped(escaped) {
    const pattern = /(https:\/\/(?:www\.linkedin\.com|github\.com)\/(?:[^\s<&]|&amp;)*|mailto:(?:[^\s<&]|&amp;)+)/g;
    return escaped.replace(pattern, function (match) {
      let url = match;
      let trailing = '';
      while (/[.,!?;:)\]]$/.test(url)) {
        trailing = url.slice(-1) + trailing;
        url = url.slice(0, -1);
      }
      if (!url) return match;
      return (
        '<a href="' + url + '" target="_blank" rel="noopener noreferrer">' + url + '</a>' + trailing
      );
    });
  }

  function renderText(text) {
    return linkifyEscaped(escapeHtml(text)).replace(/\n/g, '<br>');
  }

  function loadHistory() {
    try {
      const raw = localStorage.getItem(CHAT_STORAGE_KEY);
      if (!raw) return [];
      const data = JSON.parse(raw);
      if (!data || !Array.isArray(data.messages)) return [];
      if (typeof data.savedAt !== 'number' || Date.now() - data.savedAt > CHAT_EXPIRY_MS) {
        localStorage.removeItem(CHAT_STORAGE_KEY);
        return [];
      }
      return data.messages.filter(function (m) {
        return m && (m.role === 'user' || m.role === 'assistant') && typeof m.content === 'string';
      });
    } catch (_e) {
      return [];
    }
  }

  function saveHistory() {
    try {
      const trimmed = chatMessages.slice(-CHAT_MAX_STORED);
      localStorage.setItem(CHAT_STORAGE_KEY, JSON.stringify({ messages: trimmed, savedAt: Date.now() }));
    } catch (_e) {
      /* storage may be unavailable (private mode) */
    }
  }

  function scrollToBottom() {
    if (messagesEl) messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function appendBubble(role, content, options) {
    const opts = options || {};
    const row = document.createElement('div');
    row.className = 'cw-row cw-' + role + (opts.error ? ' cw-error' : '');
    const bubble = document.createElement('div');
    bubble.className = 'cw-bubble';
    bubble.innerHTML = renderText(content);
    row.appendChild(bubble);
    if (role === 'assistant' && opts.feedback) {
      row.appendChild(buildFeedbackBar(opts.question || '', content));
    }
    messagesEl.appendChild(row);
    scrollToBottom();
    return row;
  }

  function buildFeedbackBar(question, reply) {
    const bar = document.createElement('div');
    bar.className = 'cw-feedback';

    function makeBtn(verdict, label, emoji) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cw-feedback-btn';
      btn.setAttribute('aria-label', label);
      btn.textContent = emoji;
      btn.addEventListener('click', function () {
        sendFeedback(verdict, question, reply);
        const thanks = document.createElement('span');
        thanks.className = 'cw-feedback-thanks';
        thanks.textContent = 'Thanks for the feedback';
        bar.replaceWith(thanks);
        trackEvent('chat_feedback');
      });
      return btn;
    }

    bar.appendChild(makeBtn('up', 'Good response', '\u{1F44D}'));
    bar.appendChild(makeBtn('down', 'Bad response', '\u{1F44E}'));
    return bar;
  }

  function sendFeedback(verdict, question, reply) {
    try {
      fetch(CHAT_API_BASE + '/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          verdict: verdict,
          question: String(question).slice(0, 500),
          reply: String(reply).slice(0, 2000),
        }),
      }).catch(function () {
        /* fire-and-forget */
      });
    } catch (_e) {
      /* never break UI on feedback */
    }
  }

  function showTyping() {
    const row = document.createElement('div');
    row.className = 'cw-row cw-assistant cw-typing';
    row.id = 'chat-typing';
    row.setAttribute('role', 'status');
    row.setAttribute('aria-live', 'polite');
    row.setAttribute('aria-label', 'Assistant is typing');
    const bubble = document.createElement('div');
    bubble.className = 'cw-bubble';
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('span');
      dot.className = 'cw-dot';
      bubble.appendChild(dot);
    }
    row.appendChild(bubble);
    messagesEl.appendChild(row);
    scrollToBottom();
  }

  function hideTyping() {
    const typing = document.getElementById('chat-typing');
    if (typing) typing.remove();
  }

  function setBusy(busy) {
    chatInFlight = busy;
    updateInputState();
  }

  // In-memory mirror so the cooldown still holds when sessionStorage is
  // unavailable (Safari lockdown / storage-blocked browsers).
  let memCooldownUntil = 0;

  function cooldownRemainingMs() {
    let stored = 0;
    try {
      stored = parseInt(sessionStorage.getItem(CHAT_COOLDOWN_KEY) || '0', 10);
    } catch (_e) {
      /* storage unavailable — memCooldownUntil covers us */
    }
    return Math.max(0, stored - Date.now(), memCooldownUntil - Date.now());
  }

  function startCooldown(durationMs) {
    const until = Date.now() + (durationMs || CHAT_COOLDOWN_MS);
    memCooldownUntil = until;
    try {
      sessionStorage.setItem(CHAT_COOLDOWN_KEY, String(until));
    } catch (_e) {
      /* storage unavailable — memCooldownUntil covers us */
    }
    refreshCooldownUI();
  }

  function refreshCooldownUI() {
    if (cooldownTimer) {
      clearTimeout(cooldownTimer);
      cooldownTimer = null;
    }
    const remaining = cooldownRemainingMs();
    if (remaining > 0) {
      const mins = Math.max(1, Math.ceil(remaining / 60000));
      cooldownEl.textContent =
        'The assistant is taking a short break (high demand). Try again in about ' +
        mins + ' minute' + (mins === 1 ? '' : 's') + '.';
      cooldownEl.hidden = false;
      cooldownTimer = setTimeout(refreshCooldownUI, Math.min(remaining, 30000));
    } else {
      cooldownEl.hidden = true;
    }
    updateInputState();
  }

  function updateInputState() {
    const coolingDown = cooldownRemainingMs() > 0;
    const disabled = chatInFlight || coolingDown;
    inputEl.disabled = disabled;
    sendEl.disabled = disabled;
    const chips = chipsEl.querySelectorAll('.cw-chip');
    for (let i = 0; i < chips.length; i++) chips[i].disabled = disabled;
  }

  function buildApiHistory() {
    // Last 4 exchanged messages, each trimmed to 400 chars (contract: max 6 x 400)
    return chatMessages.slice(-4).map(function (m) {
      return { role: m.role, content: m.content.slice(0, 400) };
    });
  }

  async function sendMessage(text) {
    const message = String(text || '').trim().slice(0, 500);
    if (!message || chatInFlight || cooldownRemainingMs() > 0) return;

    const history = buildApiHistory();
    chatMessages.push({ role: 'user', content: message });
    saveHistory();
    appendBubble('user', message);
    chipsEl.hidden = true;
    inputEl.value = '';
    trackEvent('chat_message_sent');

    setBusy(true);
    showTyping();

    const controller = new AbortController();
    const timeoutId = setTimeout(function () {
      controller.abort();
    }, CHAT_TIMEOUT_MS);

    try {
      const res = await fetch(CHAT_API_BASE + '/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message, history: history }),
        signal: controller.signal,
      });

      if (res.status === 429 || res.status === 503) {
        let body = null;
        try {
          body = await res.json();
        } catch (_e) {
          /* non-JSON error body — fall back to defaults */
        }
        if (res.status === 429) {
          // Honor the server's window so a retry can actually succeed.
          const retryMs =
            body && typeof body.retryAfterSeconds === 'number' && body.retryAfterSeconds > 0
              ? body.retryAfterSeconds * 1000
              : CHAT_COOLDOWN_MS;
          startCooldown(retryMs);
          appendBubble(
            'assistant',
            "I'm getting a lot of questions right now. Please try again in a few minutes.",
            { error: true }
          );
        } else {
          // 503 = daily AI quota exhausted. Show the server's message — it is
          // user-facing copy with the contact-Rafael escape hatch.
          startCooldown(CHAT_QUOTA_COOLDOWN_MS);
          appendBubble(
            'assistant',
            body && typeof body.error === 'string' && body.error
              ? body.error
              : 'The assistant reached its free daily AI quota. Please try again tomorrow.',
            { error: true }
          );
        }
        return;
      }

      if (!res.ok) {
        appendBubble('assistant', 'Sorry, something went wrong. Please try again.', {
          error: true,
        });
        return;
      }

      const data = await res.json();
      const reply = data && typeof data.reply === 'string' ? data.reply : '';
      if (!reply) {
        appendBubble('assistant', 'Sorry, I could not generate a reply. Please try again.', {
          error: true,
        });
        return;
      }

      chatMessages.push({ role: 'assistant', content: reply });
      saveHistory();
      appendBubble('assistant', reply, { feedback: true, question: message });
    } catch (_e) {
      appendBubble('assistant', 'Connection issue, try again.', { error: true });
    } finally {
      clearTimeout(timeoutId);
      hideTyping();
      setBusy(false);
      if (!panel.hidden && !inputEl.disabled) inputEl.focus();
    }
  }

  function restoreHistory() {
    chatMessages = loadHistory();
    for (let i = 0; i < chatMessages.length; i++) {
      const m = chatMessages[i];
      if (m.role === 'assistant') {
        const question = i > 0 && chatMessages[i - 1].role === 'user' ? chatMessages[i - 1].content : '';
        appendBubble('assistant', m.content, { feedback: true, question: question });
      } else {
        appendBubble('user', m.content);
      }
    }
    if (chatMessages.length > 0) chipsEl.hidden = true;
  }

  function resetClearArm() {
    clearArmed = false;
    clearEl.classList.remove('cw-armed');
    clearHintEl.hidden = true;
    if (clearArmTimer) {
      clearTimeout(clearArmTimer);
      clearArmTimer = null;
    }
  }

  function handleClearClick() {
    if (!clearArmed) {
      // First tap: arm and ask for a second tap (no native confirm dialogs)
      clearArmed = true;
      clearEl.classList.add('cw-armed');
      clearHintEl.hidden = false;
      clearArmTimer = setTimeout(resetClearArm, 3000);
      return;
    }
    resetClearArm();
    chatMessages = [];
    try {
      localStorage.removeItem(CHAT_STORAGE_KEY);
    } catch (_e) {
      /* ignore */
    }
    const rows = messagesEl.querySelectorAll('.cw-row:not(.cw-welcome), .cw-feedback-thanks');
    for (let i = 0; i < rows.length; i++) rows[i].remove();
    chipsEl.hidden = false;
    updateInputState();
  }

  function openChat() {
    panel.hidden = false;
    fab.hidden = true;
    fab.setAttribute('aria-expanded', 'true');
    refreshCooldownUI();
    scrollToBottom();
    if (!inputEl.disabled) inputEl.focus();
    trackEvent('chat_opened');
  }

  function closeChat() {
    panel.hidden = true;
    fab.hidden = false;
    fab.setAttribute('aria-expanded', 'false');
    resetClearArm();
    fab.focus();
  }

  function initChatWidget() {
    if (!fab || !panel || !messagesEl || !formEl || !inputEl) return;

    restoreHistory();
    refreshCooldownUI();

    fab.addEventListener('click', openChat);
    closeEl.addEventListener('click', closeChat);
    clearEl.addEventListener('click', handleClearClick);

    formEl.addEventListener('submit', function (e) {
      e.preventDefault();
      sendMessage(inputEl.value);
    });

    const chips = chipsEl.querySelectorAll('.cw-chip');
    for (let i = 0; i < chips.length; i++) {
      chips[i].addEventListener('click', function (e) {
        sendMessage(e.currentTarget.textContent);
      });
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.hidden) {
        closeChat();
      }
    });
  }

  initChatWidget();

  // Expose for debugging/automation
  if (typeof window !== 'undefined') {
    window.openChatWidget = openChat;
    window.closeChatWidget = closeChat;
  }
</script>
