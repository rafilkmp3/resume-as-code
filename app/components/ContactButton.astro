---
import LiquidGlassIcon from './LiquidGlassIcon.astro';

export interface Props {
  icon: string;
  label: string;
  value: string;
  href: string;
  network?: string;
}

const { icon, label, value, href, network = '' } = Astro.props;

// Map network names to Iconify icon names
const getIconName = (network: string, fallbackIcon: string) => {
  const iconMap: Record<string, string> = {
    'LinkedIn': 'simple-icons:linkedin',
    'GitHub': 'simple-icons:github',
    'WhatsApp': 'simple-icons:whatsapp',
    'cal.com': 'heroicons:calendar',
    'Email': 'heroicons:envelope'
  };

  // If fallbackIcon is already an Iconify name (contains ':'), use it directly
  if (fallbackIcon.includes(':')) {
    return fallbackIcon;
  }

  // If fallbackIcon is a URL (contains 'http'), ignore it and use network mapping
  if (fallbackIcon.includes('http')) {
    return iconMap[network] || 'heroicons:link';
  }

  return iconMap[network] || iconMap[fallbackIcon] || 'heroicons:link';
};

const iconName = getIconName(network, icon);
---

<a
  href={href}
  class="apple-contact-badge group"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${label}: ${value}`}
  data-contact-type={network.toLowerCase() || label.toLowerCase()}
  data-contact-value={value}
>
  <div class="apple-contact-icon">
    <LiquidGlassIcon name={iconName} size={20} variant="subtle" />
  </div>
  <div class="apple-contact-info">
    <div class="apple-contact-label">
      {label}
    </div>
    <div class="apple-contact-value">
      {value}
    </div>
  </div>
</a>

<style>
  /* Apple-Style Contact Badge — draws from the shared liquid-glass tokens
     (app/styles/global.css) so it matches every other glass surface. */
  .apple-contact-badge {
    display: flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--glass-surface);
    backdrop-filter: var(--glass-filter-sm);
    -webkit-backdrop-filter: var(--glass-filter-sm);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius); /* Apple HIG rounded corners */
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--glass-shadow);
    min-width: 0; /* Allow flex shrinkage */
    width: 100%; /* Full width for better text space */
    box-sizing: border-box;
    /* Smart text handling - prevents awkward line breaks */
    container-type: inline-size; /* Enable container queries */
  }

  .apple-contact-badge:hover {
    background: var(--glass-hover-bg);
    transform: translateY(-2px) scale(1.02);
    /* Deeper lift shadow — no dedicated hover-shadow token to reference */
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .apple-contact-icon {
    width: var(--tap-min);
    height: var(--tap-min);
    /* Liquid Glass Background — mirrors the LiquidGlassIcon component. This
       gradient + inset-highlight recipe has no flat token, so it stays raw;
       the material primitives (filter/radius) use the shared tokens. */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0.1) 100%
    );
    backdrop-filter: var(--glass-filter);
    -webkit-backdrop-filter: var(--glass-filter);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--glass-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: var(--space-3);
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    /* Enhanced shadows for depth */
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .apple-contact-badge:hover .apple-contact-icon {
    transform: translateY(-2px) scale(1.05);
    /* Enhanced lighting on hover */
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(255, 255, 255, 0.15) 100%
    );
    /* Intensified shadows and highlights */
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 2px 0 rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .apple-contact-info {
    flex: 1;
    min-width: 0; /* Allows text truncation */
    overflow: hidden; /* Prevent content overflow */
  }

  .apple-contact-label {
    font-size: var(--text-caption); /* 13px — HIG caption */
    font-weight: var(--fw-medium);
    line-height: var(--lh-heading);
    color: var(--foreground-muted); /* secondary label */
    margin-bottom: var(--space-1);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    white-space: nowrap; /* Prevent label wrapping */
  }

  .apple-contact-value {
    font-size: var(--text-footnote); /* 14px */
    font-weight: var(--fw-semibold);
    line-height: var(--lh-heading);
    color: var(--foreground);
    /* Emails/URLs must break WITHOUT an inserted hyphen (hyphens:auto was
       rendering "gmail.-com"). anywhere breaks long tokens cleanly. */
    overflow-wrap: anywhere;
    word-break: normal;
    hyphens: none;
    /* Default: Single line with ellipsis */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Container queries for responsive text handling */
  @container (min-width: 200px) {
    .apple-contact-value {
      white-space: normal; /* Allow wrapping on wider containers */
      overflow: visible;
      text-overflow: unset;
      word-spacing: -0.02em; /* Tighter word spacing for better fit */
    }
  }

  /* Enhanced responsive breakpoints for contact badges */
  @media (max-width: 640px) {
    .apple-contact-badge {
      padding: var(--space-3); /* Tighter, even padding on mobile */
      min-height: var(--tap-min); /* HIG touch target (44px floor) */
    }

    .apple-contact-value {
      font-size: var(--text-footnote); /* 14px on mobile */
      line-height: var(--lh-heading);
      /* Mobile: Allow controlled wrapping */
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
      hyphens: none;
      overflow-wrap: anywhere;
      word-break: normal;
      /* Limit to 2 lines maximum on mobile */
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  /* Dark theme — the badge surface/border/shadow now flow from the shared
     glass tokens, which redefine themselves under .dark, so the badge adapts
     automatically. Only the non-tokenized pieces keep explicit dark overrides:
     the hover lift shadow and the liquid-glass icon gradient recipe. */
  :global(.dark) .apple-contact-badge:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
  }

  :global(.dark) .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.05) 100%
    );
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 1px 0 rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.dark) .apple-contact-badge:hover .apple-contact-icon {
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.04) 50%,
      rgba(255, 255, 255, 0.08) 100%
    );
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 2px 0 rgba(255, 255, 255, 0.08);
  }
</style>
