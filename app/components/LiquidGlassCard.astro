---
export interface Props {
  class?: string;
  style?: string;
  variant?: 'default' | 'intense' | 'subtle';
}

const { class: className = '', style = '', variant = 'default' } = Astro.props;
---

<div
  class={`glass-card glass-card--${variant} ${className}`}
  style={style}
>
  <slot />
</div>

<!-- The .glass-card surface + its variant modifiers live in app/styles/global.css
     (single glass token source) so section cards and nested skill sub-cards share
     one material. The variant prop now actually renders (default/intense/subtle). -->
